<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Ecuzen" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->

        <!-- Secondary brand color. -->
    <!--    <item name="alertDialogTheme">@style/AlertDialogThemeDark</item>-->
        <item name="colorControlNormal">@color/white</item>
        <item name="autoCompleteTextViewStyle">@style/cursorColor</item>

        <!-- Customize your theme here. -->
        <item name="android:windowDisablePreview">true</item>
       <!--   <item name="homeAsUpIndicator">@drawable/ic_back_arrow</item>-->
        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>
        <item name="android:navigationBarColor">@color/black</item>
        <item name="android:windowLightStatusBar">false</item>

    </style>

    <style name="Introscreen" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/blue_app</item>
        <item name="colorPrimaryDark">@color/blue_app</item>
        <item name="android:colorControlNormal">@color/white</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:statusBarColor">@color/blue_app</item>

    </style>

    <style name="ThemeAppButton" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/heightsize_68dp</item>
        <item name="android:textAlignment">center</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:letterSpacing">0.03</item>
        <item name="android:fontFamily">@font/dmsans_medium</item>
        <item name="android:textSize">@dimen/heightsize_15dp</item>
        <item name="elevation">@dimen/heightsize_2dp</item>
        <item name="cornerRadius">@dimen/heightsize_10dp</item>
        <item name="android:layout_marginStart">@dimen/heightsize_32dp</item>
        <item name="android:layout_marginEnd">@dimen/heightsize_32dp</item>
    </style>

    <style name="fab_3_rounded">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
        <item name="cornerSizeTopLeft">10dp</item>
        <item name="cornerSizeTopRight">10dp</item>
        <item name="cornerSizeBottomLeft">10dp</item>
        <item name="cornerSizeBottomRight">10dp</item>
    </style>


    <style name="TitleStyle" parent="android:Widget.TextView">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:letterSpacing">-0.03</item>
        <item name="android:textSize">18sp</item>
        <item name="fontFamily">@font/dmsans_bold</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="TitleStyle2" parent="android:Widget.TextView">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:letterSpacing">-0.03</item>
        <item name="android:textSize">22sp</item>
        <item name="fontFamily">@font/dmsans_bold</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="labelStyle" parent="android:Widget.TextView">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:textSize">16sp</item>
        <item name="fontFamily">@font/dmsans_bold</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="viewtextStyle" parent="android:Widget.TextView">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/color_464646</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:textSize">16sp</item>
        <item name="fontFamily">@font/dmsans_regular</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="SettingSubTitleStyle" parent="android:Widget.TextView">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/blue_app</item>
        <item name="android:textSize">@dimen/heightsize_15dp</item>
        <item name="fontFamily">@font/dmsans_regular</item>

        <item name="android:includeFontPadding">false</item>
    </style>


    <style name="cardlabelStyle" parent="android:Widget.TextView">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:textSize">12sp</item>
        <item name="fontFamily">@font/dmsans_bold</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="cardtextStyle" parent="android:Widget.TextView">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/color_464646</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:textSize">12sp</item>
        <item name="fontFamily">@font/dmsans_regular</item>
        <item name="android:includeFontPadding">false</item>
    </style>


    <style name="TextInputLayoutStyle" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense">
        <item name="boxStrokeColor">@color/color_hint</item>
        <item name="android:layout_width">match_parent</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="android:layout_height">@dimen/heightsize_50dp</item>
        <item name="boxStrokeWidthFocused">1dp</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/heightsize_12dp</item>
        <item name="boxCornerRadiusBottomStart">@dimen/heightsize_12dp</item>
        <item name="boxCornerRadiusTopEnd">@dimen/heightsize_12dp</item>
        <item name="boxCornerRadiusTopStart">@dimen/heightsize_12dp</item>
        <item name="cornerRadius">@dimen/heightsize_12dp</item>
        <item name="colorControlNormal">@color/white_60</item>
        <item name="fontFamily">@font/dmsans_regular</item>
        <item name="autoCompleteTextViewStyle">@style/cursorColor</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textColorHint">@color/white_60</item>
        <item name="hintTextColor">@color/color_hint</item>
        <item name="placeholderTextColor">@color/white_60</item>
    </style>

    <style name="cursorColor" parent="Widget.AppCompat.AutoCompleteTextView">
        <item name="android:textCursorDrawable">@drawable/cursor</item>
    </style>


    <style name="Toolbar.TitleText" parent="TextAppearance.Widget.AppCompat.Toolbar.Title">
        <item name="android:textSize">16sp</item>
        <item name="fontFamily">@font/dmsans_medium</item>
        <item name="singleLine">true</item>
        <item name="android:textColor">@color/white</item>

    </style>

    <style name="dropdown" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="boxStrokeColor">@color/white</item>
        <item name="android:layout_width">match_parent</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="endIconTint">@color/white_60</item>
        <item name="background">@color/white</item>
        <item name="backgroundColor">@color/white</item>
        <item name="android:layout_height">60dp</item>
        <item name="boxStrokeWidthFocused">1dp</item>
        <item name="boxCornerRadiusBottomEnd">9dp</item>
        <item name="boxCornerRadiusBottomStart">9dp</item>
        <item name="boxCornerRadiusTopEnd">9dp</item>.
        <item name="boxCornerRadiusTopStart">9dp</item>
        <item name="cornerRadius">9dp</item>
        <item name="colorControlNormal">@color/white_60</item>
        <item name="fontFamily">@font/dmsans_regular</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textColorHint">@color/white_60</item>
        <item name="hintTextColor">@color/color_hint</item>
        <!-- The color of the label when it is collapsed and the text field is active -->
        <!--  <item name="colorControlActivated">@color/colorFFB44C</item>-->
        <item name="materialThemeOverlay">@style/AppTheme.ExposedDropdownMenu.MaterialThemeOverlay</item></style>




    <style name="AppTheme.ExposedDropdownMenu.MaterialThemeOverlay" parent="Theme.MaterialComponents.Light.DarkActionBar">
        <!-- background color of dropdown (popup) items -->
        <item name="colorSurface">@color/white</item>
        <item name="android:popupElevation">8dp</item>
    </style>

    <style name="navTextInactive">
        <item name="android:fontFamily">@font/dmsans_medium</item>
        <item name="android:textSize">10sp</item>
    </style>

    <style name="navTextActive">
        <item name="android:fontFamily">@font/dmsans_medium</item>
        <item name="android:textSize">10sp</item>
    </style>

    <style name="AppTabLayout" parent="Widget.Design.TabLayout">
        <item name="tabBackground">@null</item>
        <item name="tabTextAppearance">@style/AppTabTextAppearance</item>
        <item name="tabSelectedTextColor">@color/white</item>

    </style>

    <style name="AppTabTextAppearance" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">#696969</item>
        <item name="textAllCaps">false</item>
        <item name="android:gravity">center</item>
    </style>


    <declare-styleable name="OtpView">
        <attr format="integer" name="OtpItemCount"/>
        <attr format="dimension" name="OtpItemWidth"/>
        <attr format="dimension" name="OtpItemHeight"/>
        <attr format="dimension" name="OtpItemRadius"/>
        <attr format="dimension" name="OtpItemSpacing"/>
        <attr format="dimension" name="OtpLineWidth"/>
        <attr format="reference|color" name="OtpLineColor"/>
        <attr format="enum" name="OtpViewType">
            <enum name="rectangle" value="0"/>
            <enum name="line" value="1"/>
            <enum name="none" value="2"/>
        </attr>
        <attr name="android:cursorVisible"/>
        <attr name="android:textAllCaps"/>
        <attr format="dimension" name="OtpCursorWidth"/>
        <attr format="reference|color" name="OtpCursorColor"/>
        <attr name="android:itemBackground"/>
        <attr format="boolean" name="OtpHideLineWhenFilled"/>
        <attr format="boolean" name="OtpState_filled"/>
        <attr format="boolean" name="OtpRtlTextDirection"/>
        <attr format="string" name="OtpMaskingChar"/>
    </declare-styleable>
    <declare-styleable name="OtpViewTheme">
        <attr format="reference" name="otpViewStyle"/>
    </declare-styleable>
    <dimen name="otp_view_cursor_width">2dp</dimen>
    <dimen name="otp_view_item_line_width">2dp</dimen>
    <dimen name="otp_view_item_radius">5dp</dimen>
    <dimen name="otp_view_item_size">48dp</dimen>
    <dimen name="otp_view_item_spacing">5dp</dimen>

    <style name="MyDialogTheme" parent="android:Theme.Material.Light.Dialog">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/blue_app</item>
        <item name="colorPrimaryVariant">@color/blue_app</item>
        <item name="colorOnPrimary">@color/black</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/blue_app</item>
        <item name="colorSecondaryVariant">@color/blue_app</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:datePickerStyle">@style/MyDatePicker</item>
    </style>

    <style name="MyDatePicker" parent="android:Widget.Material.Light.DatePicker">
        <item name="android:datePickerMode">spinner</item>
        <item name="colorAccent">#367D88</item>
        <item name="android:windowTranslucentStatus">true</item>
    </style>

    <style name="CustomBottomSheetDialogThemeWithDim" parent="Theme.MaterialComponents.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/CustomBottomSheetStyle</item>
        <item name="android:windowSoftInputMode">adjustResize|stateHidden</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:colorBackground">@color/color_F5EBEB</item>
        <item name="android:statusBarColor">@color/transparent</item>
        <item name="android:background">@color/transparent</item>
        <item name="android:windowBackground">@null</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.3</item>
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:windowFrame">@null</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:navigationBarColor">@color/black</item>

    </style>

    <style name="CustomBottomSheetStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
    </style>

    <style name="circleImageView" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="customTabTextAppearance" parent="TextAppearance.Design.Tab">
        <item name="fontFamily">@font/dmsans_medium</item>
        <item name="android:textSize">15sp</item>
        <item name="textAllCaps">false</item>
    </style>

</resources>