<?xml version="1.0" encoding="utf-8"?>
<layout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/color_F5EBEB"
        tools:context="com.MyProfileActivity">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/collapseView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:elevation="@dimen/heightsize_4dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_collapseParallaxMultiplier="0.7">

            <ImageView
                android:id="@+id/imageView7"
                android:layout_width="match_parent"
                android:layout_height="150sp"
                android:adjustViewBounds="true"
                android:scaleType="centerCrop"
                android:src="@color/color_app"
                app:layout_constraintDimensionRatio="25:17"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />


            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/llprofile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="48dp"
                android:paddingBottom="16dp"
                app:layout_constraintTop_toBottomOf="@id/imageView7">


                <TextView
                    android:id="@+id/tvUserName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:fontFamily="@font/dmsans_bold"
                    android:includeFontPadding="false"
                    android:letterSpacing="-0.012"
                    android:text="Amit Yadav"
                    android:textColor="@color/blue_app"
                    android:textSize="30sp"
                    app:layout_constraintEnd_toStartOf="@+id/tvUserage"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvUserage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:fontFamily="@font/dmsans_regular"
                    android:includeFontPadding="false"
                    android:letterSpacing="-0.012"
                    android:text=""
                    android:textColor="@color/white"
                    android:textSize="30sp"
                    app:layout_constraintStart_toEndOf="@+id/tvUserName"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/designation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/dmsans_regular"
                    android:includeFontPadding="false"
                    android:paddingTop="@dimen/heightsize_7dp"
                    android:text=""
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:visibility="gone"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tvUserName" />

                <TextView
                    android:id="@+id/tvCreated"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/dmsans_regular"
                    android:includeFontPadding="true"
                    android:text=""
                    android:textColor="@color/white_60"
                    android:textSize="13sp"
                    android:visibility="gone"
                    app:layout_constraintStart_toStartOf="@+id/designation"
                    app:layout_constraintTop_toBottomOf="@+id/designation" />

            </androidx.constraintlayout.widget.ConstraintLayout>


            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/civUserImage"
                android:layout_width="@dimen/_65sdp"
                android:layout_height="@dimen/_65sdp"
                android:layout_marginStart="@dimen/_20sdp"
                android:background="@drawable/profile"
                android:padding="@dimen/heightsize_1dp"
                android:elevation="8dp"
                app:civ_border_color="@color/white"
                app:civ_border_width="3sp"
                app:shapeAppearanceOverlay="@style/circleImageView"
                app:strokeColor="#3DF2F2F2"
                app:strokeWidth="@dimen/heightsize_2dp"
                app:layout_constraintBottom_toTopOf="@+id/llprofile"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/imageView7" />

            <View
                android:layout_width="match_parent"
                android:layout_height="0.3dp"
                android:background="#d8d8d8"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>


        </androidx.constraintlayout.widget.ConstraintLayout>


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/ctl"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/heightsize_16dp"
        android:elevation="@dimen/heightsize_4dp"
        android:background="@color/white"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/collapseView">

        <View
            android:id="@+id/view"
            android:layout_width="0dp"
            android:layout_height="0.30sp"
            android:background="#d8d8d8"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/lluserprofile"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingVertical="@dimen/heightsize_12dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/view">

            <ImageView
                android:id="@+id/ivMyProfile"
                android:layout_width="@dimen/heightsize_24dp"
                android:layout_height="@dimen/heightsize_24dp"
                android:layout_marginStart="20sp"
                android:src="@drawable/profile"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                tools:ignore="MissingConstraints" />


            <TextView
                android:id="@+id/tvMYProfile"
                style="@style/SettingSubTitleStyle"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:gravity="top"
                android:layout_marginStart="16sp"
                android:text="@string/txt_my_profile"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/ivMyProfile"
                app:layout_constraintTop_toTopOf="parent"
                tools:ignore="MissingConstraints" />



        </androidx.constraintlayout.widget.ConstraintLayout>


        <View
            android:id="@+id/view1"
            android:layout_width="0dp"
            android:layout_height="0.30sp"
            android:background="#d8d8d8"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />


    </androidx.constraintlayout.widget.ConstraintLayout>



    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>
