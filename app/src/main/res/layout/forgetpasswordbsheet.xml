<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">


    <RelativeLayout
        android:id="@+id/rootview"
        android:layout_width="match_parent"
        android:orientation="vertical"
        android:background="@color/transparent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="@drawable/rectangle_solid_white_top_rounded_16"
            android:orientation="vertical">





            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <View
                    android:layout_width="@dimen/heightsize_60dp"
                    android:layout_gravity="center"
                    android:background="@color/white_60"
                    android:layout_marginTop="10dp"
                    android:layout_height="3dp">

                </View>

                <TextView
                    android:id="@+id/tvtvtitle"
                    style="@style/TitleStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/heightsize_10dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/text_forget_password"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    android:visibility="visible" />


            </LinearLayout>




            <LinearLayout
                android:layout_width="match_parent"
                android:orientation="vertical"
                android:layout_marginTop="@dimen/heightsize_5dp"


                android:layout_height="wrap_content">


            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tildiluteName"
                style="@style/TextInputLayoutStyle"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginHorizontal="@dimen/heightsize_16dp"
                android:layout_marginTop="@dimen/heightsize_18dp"
                android:layout_marginBottom="@dimen/heightsize_10dp"
                android:hint="@string/lbl_email"
                app:placeholderText="@string/placeholder_text_email">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etemail"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/heightsize_60dp"
                    android:fontFamily="@font/dmsans_regular"
                    android:imeOptions="actionDone"
                    android:textCursorDrawable="@drawable/cursor"
                    android:inputType="textEmailAddress"
                    android:textColor="@color/black" />
            </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>


            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfirm"
                style="@style/ThemeAppButton"
                android:layout_marginStart="@dimen/heightsize_16dp"
                android:layout_marginBottom="@dimen/heightsize_26dp"
                android:backgroundTint="@color/color_F72F20"
                android:layout_marginTop="@dimen/heightsize_20dp"
                android:onClick="onClick"
                android:text="@string/btn_text_submit"
                android:textAllCaps="false" />
        </LinearLayout>



    </RelativeLayout>

</layout>