<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/swipeToRefresh"
        android:layout_width="match_parent"
        android:background="@color/white"
        android:layout_height="match_parent">

           <androidx.core.widget.NestedScrollView
               android:layout_width="match_parent"
               android:layout_height="0dp"
               android:fillViewport="true"
               android:scrollbars="none"
               app:layout_constraintStart_toStartOf="parent"
               app:layout_constraintTop_toTopOf="parent"
               app:layout_constraintBottom_toBottomOf="parent"
               app:layout_constraintEnd_toEndOf="parent">

               <androidx.constraintlayout.widget.ConstraintLayout
                   android:layout_width="match_parent"
                   android:layout_height="match_parent"
                   app:layout_constraintStart_toStartOf="parent"
                   app:layout_constraintTop_toTopOf="parent"
                   app:layout_constraintBottom_toBottomOf="parent"
                   app:layout_constraintEnd_toEndOf="parent"
                   tools:context=".fragments.HomeFragment">

                   <ImageView
                       android:layout_width="wrap_content"
                       android:id="@+id/image"
                       android:layout_height="wrap_content"
                       android:layout_gravity="center"
                       android:layout_marginVertical="30sp"
                       android:fontFamily="@font/dmsans_bold"
                       android:src="@drawable/group_277"
                       app:tint="@color/color_C5C5C5"
                       app:layout_constraintTop_toTopOf="parent"
                       app:layout_constraintStart_toStartOf="parent"
                       app:layout_constraintEnd_toEndOf="parent" />

                   <TextView
                       android:id="@+id/lbl_support"
                       android:layout_height="@dimen/_20sdp"
                       android:layout_width="@dimen/_80sdp"
                       android:layout_marginTop="@dimen/heightsize_16dp"
                       app:layout_constraintTop_toBottomOf="@+id/image"
                       android:background="@color/color_C5C5C5"
                       app:layout_constraintStart_toStartOf="parent"
                       app:layout_constraintEnd_toEndOf="parent" />

                   <com.google.android.material.card.MaterialCardView
                       android:layout_width="match_parent"
                       android:id="@+id/materialcard"
                       app:cardElevation="@dimen/heightsize_6dp"
                       app:layout_constraintTop_toBottomOf="@+id/lbl_support"
                       app:layout_constraintStart_toStartOf="parent"
                       app:layout_constraintEnd_toEndOf="parent"
                       android:layout_marginTop="@dimen/heightsize_16dp"
                       android:layout_marginHorizontal="@dimen/_16sdp"
                       app:cardBackgroundColor="@color/color_C5C5C5"
                       app:cardCornerRadius="@dimen/_10sdp"
                       android:layout_height="@dimen/_150sdp"/>

                   <View
                       android:layout_width="wrap_content"
                       android:id="@+id/view1"
                       app:layout_constraintStart_toStartOf="parent"
                       android:layout_marginTop="@dimen/heightsize_24dp"
                       app:layout_constraintTop_toBottomOf="@+id/materialcard"
                       android:background="@color/color_C7BFBF"
                       android:layout_height="0.5dp"/>

                   <LinearLayout
                       android:id="@+id/llayout"
                       android:layout_width="match_parent"
                       android:layout_height="@dimen/_80sdp"
                       android:gravity="center_horizontal"
                       android:orientation="horizontal"
                       android:layout_marginBottom="5sp"
                       android:background="@color/color_C5C5C5"
                       app:layout_constraintEnd_toEndOf="parent"
                       app:layout_constraintStart_toStartOf="parent"
                       app:layout_constraintTop_toBottomOf="@+id/view1">
                   </LinearLayout>

                   <View
                       android:layout_width="wrap_content"
                       android:id="@+id/view2"
                       app:layout_constraintStart_toStartOf="parent"
                       app:layout_constraintTop_toBottomOf="@+id/llayout"
                       android:background="@color/color_C7BFBF"
                       android:layout_height="0.5dp"/>
               </androidx.constraintlayout.widget.ConstraintLayout>

           </androidx.core.widget.NestedScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>