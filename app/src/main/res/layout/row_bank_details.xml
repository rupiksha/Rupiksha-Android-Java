<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilBankName"
            style="@style/TextInputLayoutStyle"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/heightsize_16dp"
            android:layout_marginTop="@dimen/_8sdp"
            android:backgroundTint="@color/app_35383F"
            app:hintEnabled="false"
            android:elevation="@dimen/_2sdp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etBankName"
                android:layout_width="match_parent"
                android:layout_height="@dimen/heightsize_55dp"
                android:background="@drawable/edittext_layout_background"
                android:fontFamily="@font/dmsans_regular"
                android:hint="@string/lbl_account_name"
                android:imeOptions="actionNext"
                android:inputType="textCapSentences"
                android:textColor="@color/app_1E1E1E"
                android:textColorHint="@color/app_1E1E1E_40" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilAccountNumber"
            style="@style/TextInputLayoutStyle"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/heightsize_16dp"
            android:layout_marginTop="@dimen/_8sdp"
            android:backgroundTint="@color/app_35383F"
            app:hintEnabled="false"
            android:elevation="@dimen/_2sdp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tilBankName">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etAccountNumber"
                android:layout_width="match_parent"
                android:layout_height="@dimen/heightsize_55dp"
                android:background="@drawable/edittext_layout_background"
                android:fontFamily="@font/dmsans_regular"
                android:hint="@string/lbl_account_number1"
                android:imeOptions="actionNext"
                android:inputType="number"
                android:textColor="@color/app_1E1E1E"
                android:textColorHint="@color/app_1E1E1E_40" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilIfscCode"
            style="@style/TextInputLayoutStyle"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/heightsize_16dp"
            android:layout_marginTop="@dimen/_8sdp"
            android:backgroundTint="@color/app_35383F"
            app:hintEnabled="false"
            android:elevation="@dimen/_2sdp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tilAccountNumber">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etIfscCode"
                android:layout_width="match_parent"
                android:layout_height="@dimen/heightsize_55dp"
                android:background="@drawable/edittext_layout_background"
                android:fontFamily="@font/dmsans_regular"
                android:hint="@string/lbl_ifsc_code1"
                android:imeOptions="actionNext"
                android:inputType="textCapCharacters"
                android:textColor="@color/app_1E1E1E"
                android:textColorHint="@color/app_1E1E1E_40" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilAccountType"
            style="@style/dropdown"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/heightsize_16dp"
            android:layout_marginTop="@dimen/_8sdp"
            android:backgroundTint="@color/app_35383F"
            android:elevation="@dimen/_2sdp"
            app:hintEnabled="false"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tilIfscCode">

            <AutoCompleteTextView
                android:id="@+id/etAccountType"
                android:layout_width="match_parent"
                android:layout_height="@dimen/heightsize_55dp"
                android:background="@drawable/edittext_layout_background"
                android:baselineAligned="false"
                android:hint="@string/placeholder_account_type"
                android:imeOptions="actionNext"
                android:inputType="text"
                android:focusable="false"
                android:cursorVisible="false"
                android:paddingHorizontal="@dimen/heightsize_11dp"
                android:popupBackground="@color/color_E3F2FD"
                android:textColor="@color/app_1E1E1E"
                android:textColorHint="@color/app_1E1E1E_40" />
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:id="@+id/llBankStatement"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_100sdp"
            android:layout_marginHorizontal="@dimen/heightsize_16dp"
            android:orientation="horizontal"
            android:paddingVertical="@dimen/_4sdp"
            app:layout_constraintTop_toBottomOf="@+id/tilAccountType">

            <ImageView
                android:id="@+id/imgUploadBankStatement"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/heightsize_5dp"
                android:layout_weight="0.8"
                android:scaleType="fitXY"
                android:src="@drawable/upload_bankstatment"></ImageView>


            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="@dimen/heightsize_5dp"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="@dimen/heightsize_8dp"
                app:cardElevation="4dp"
                app:layout_constraintTop_toTopOf="parent">


                <TextView
                    android:id="@+id/txtBankStatement"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:padding="@dimen/heightsize_8dp"
                    android:fontFamily="@font/dmsans_medium"
                    android:textSize="@dimen/textsize_15sp"
                    android:textColor="@color/black"
                    android:visibility="gone"
                    android:text=""/>

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/imgBankStatement"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scaleType="centerCrop"
                    android:src="@drawable/bank_statment_des"
                    app:layout_constraintTop_toTopOf="parent" />

            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>


        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddDetail"
            style="@style/ThemeAppButton"
            android:layout_height="@dimen/_34sdp"
            android:layout_width="wrap_content"
            app:cornerRadius="@dimen/_4sdp"
            android:layout_marginTop="@dimen/heightsize_8dp"
            android:backgroundTint="@color/color_F72F20"
            android:text="@string/txt_bank_detail"
            android:layout_marginBottom="@dimen/_24sdp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/llBankStatement" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>
