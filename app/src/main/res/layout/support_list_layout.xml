<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">


    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:id="@+id/materialcard"
        app:cardElevation="@dimen/heightsize_6dp"
        app:layout_constraintTop_toBottomOf="@+id/image"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="@dimen/heightsize_16dp"
        android:layout_marginHorizontal="@dimen/_16sdp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="@dimen/_10sdp"
        android:layout_height="wrap_content">


        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:paddingTop="@dimen/heightsize_12dp"
            android:paddingBottom="@dimen/heightsize_12dp"
            android:layout_height="match_parent">



            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:id="@+id/line1"
                android:layout_marginHorizontal="@dimen/heightsize_16dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_height="wrap_content">


                <TextView
                    android:id="@+id/lbl_id"
                    style="@style/cardlabelStyle"
                    android:minWidth="130sp"
                    android:layout_width="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text="@string/lbl_tickt_id"

                    app:layout_constraintStart_toStartOf="parent"
                    />

                <TextView
                    android:id="@+id/c_id"
                    style="@style/cardtextStyle"
                    android:minWidth="100sp"
                    android:layout_width="0dp"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text=""
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/lbl_id"
                    />

                <View
                    android:layout_width="wrap_content"
                    android:layout_marginTop="7sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/c_id"
                    android:background="@color/color_C7BFBF"
                    android:layout_height="0.5dp">

                </View>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:id="@+id/line2"
                android:layout_marginHorizontal="@dimen/heightsize_16dp"
                app:layout_constraintTop_toBottomOf="@+id/line1"
                android:layout_marginTop="10sp"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_height="wrap_content">


                <TextView
                    android:id="@+id/lbl_service"
                    style="@style/cardlabelStyle"
                    android:minWidth="130sp"
                    android:layout_width="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text="@string/lbl_service"

                    app:layout_constraintStart_toStartOf="parent"
                    />

                <TextView
                    android:id="@+id/servicename"
                    style="@style/cardtextStyle"
                    android:minWidth="100sp"
                    android:layout_width="0dp"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text=""
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/lbl_service"
                    />

                <View
                    android:layout_width="wrap_content"
                    android:layout_marginTop="7sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/servicename"
                    android:background="@color/color_C7BFBF"
                    android:layout_height="0.5dp">

                </View>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:id="@+id/line3"
                android:layout_marginHorizontal="@dimen/heightsize_16dp"
                app:layout_constraintTop_toBottomOf="@+id/line2"
                android:layout_marginTop="10sp"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_height="wrap_content">


                <TextView
                    android:id="@+id/lbl_txid"
                    style="@style/cardlabelStyle"
                    android:minWidth="130sp"
                    android:layout_width="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text="@string/lbl_tx_id"

                    app:layout_constraintStart_toStartOf="parent"
                    />

                <TextView
                    android:id="@+id/tx_id"
                    style="@style/cardtextStyle"
                    android:minWidth="100sp"
                    android:layout_width="0dp"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text=""
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/lbl_txid"
                    />

                <View
                    android:layout_width="wrap_content"
                    android:layout_marginTop="7sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tx_id"
                    android:background="@color/color_C7BFBF"
                    android:layout_height="0.5dp">

                </View>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:id="@+id/line4"
                android:layout_marginHorizontal="@dimen/heightsize_16dp"
                app:layout_constraintTop_toBottomOf="@+id/line3"
                android:layout_marginTop="10sp"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_height="wrap_content">


                <TextView
                    android:id="@+id/message"
                    style="@style/cardlabelStyle"
                    android:minWidth="130sp"
                    android:layout_width="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text="@string/lbl_message"

                    app:layout_constraintStart_toStartOf="parent"
                    />

                <TextView
                    android:id="@+id/tvMessage"
                    style="@style/cardtextStyle"
                    android:minWidth="100sp"
                    android:layout_width="0dp"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text=""
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/message"
                    />

                <View
                    android:layout_width="wrap_content"
                    android:layout_marginTop="7sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tvMessage"
                    android:background="@color/color_C7BFBF"
                    android:layout_height="0.5dp">

                </View>

            </androidx.constraintlayout.widget.ConstraintLayout>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:id="@+id/line7"
                android:layout_marginHorizontal="@dimen/heightsize_16dp"
                app:layout_constraintTop_toBottomOf="@+id/line4"
                android:layout_marginTop="10sp"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_height="wrap_content">


                <TextView
                    android:id="@+id/adminMsg"
                    style="@style/cardlabelStyle"
                    android:minWidth="130sp"
                    android:layout_width="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text="@string/lbl_admin_msg"

                    app:layout_constraintStart_toStartOf="parent"
                    />

                <TextView
                    android:id="@+id/tvadmin"
                    style="@style/cardtextStyle"
                    android:minWidth="100sp"
                    android:layout_width="0dp"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text=""
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/adminMsg"
                    />

                <View
                    android:layout_width="wrap_content"
                    android:layout_marginTop="7sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tvadmin"
                    android:background="@color/color_C7BFBF"
                    android:layout_height="0.5dp">

                </View>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:id="@+id/line5"
                android:layout_marginHorizontal="@dimen/heightsize_16dp"
                app:layout_constraintTop_toBottomOf="@+id/line7"
                android:layout_marginTop="10sp"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_height="wrap_content">


                <TextView
                    android:id="@+id/lbl_date"
                    style="@style/cardlabelStyle"
                    android:minWidth="130sp"
                    android:layout_width="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text="@string/lbl_date"

                    app:layout_constraintStart_toStartOf="parent"
                    />

                <TextView
                    android:id="@+id/date"
                    style="@style/cardtextStyle"
                    android:minWidth="100sp"
                    android:layout_width="0dp"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text=""
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/lbl_date"
                    />

                <View
                    android:layout_width="wrap_content"

                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/date"
                    android:background="@color/color_C7BFBF"
                    android:layout_height="0.5dp">

                </View>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:id="@+id/line6"
                android:layout_marginHorizontal="@dimen/heightsize_16dp"
                app:layout_constraintTop_toBottomOf="@+id/line5"
                android:layout_marginTop="10sp"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_height="wrap_content">


                <TextView
                    android:id="@+id/lbl_status"
                    style="@style/cardlabelStyle"
                    android:minWidth="130sp"
                    android:layout_width="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text="@string/lbl_status"

                    app:layout_constraintStart_toStartOf="parent"
                    />

                <TextView
                    android:id="@+id/status"
                    style="@style/cardtextStyle"
                    android:minWidth="100sp"
                    android:layout_width="0dp"
                    android:textColor="@color/color_259A2A"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text=""
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/lbl_status"
                    />

                <View
                    android:layout_width="wrap_content"
                    android:layout_marginTop="7sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/status"
                    android:background="@color/color_C7BFBF"
                    android:layout_height="0.5dp">

                </View>

            </androidx.constraintlayout.widget.ConstraintLayout>





        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>


</layout>