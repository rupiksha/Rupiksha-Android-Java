<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:background="@color/white"
            android:layout_height="wrap_content">
            <View
                android:layout_width="wrap_content"
                android:id="@+id/view1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:background="@color/color_C7BFBF"
                android:layout_height="0.5dp">

            </View>

            <LinearLayout
                android:layout_width="match_parent"
                android:id="@+id/line4"
                android:orientation="horizontal"
                android:weightSum="5"
                android:layout_marginTop="@dimen/heightsize_8dp"
                android:layout_marginHorizontal="@dimen/heightsize_16dp"
                app:layout_constraintTop_toBottomOf="@+id/view1"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_height="wrap_content">


                <TextView
                    android:id="@+id/valueaccountnumber"
                    style="@style/cardlabelStyle"
                    android:gravity="center_vertical"
                    android:minWidth="@dimen/heightsize_60dp"
                    android:layout_height="match_parent"
                    android:layout_width="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text="@string/txt_data"

                    app:layout_constraintStart_toStartOf="parent"
                    />

                <TextView
                    android:id="@+id/valuename"
                    style="@style/cardtextStyle"
                    android:gravity="center_vertical"
                    android:layout_height="match_parent"
                    android:layout_width="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text=""
                    android:layout_weight="4"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/lbl_name"
                    />


                <TextView
                    android:id="@+id/amount"
                    style="@style/cardtextStyle"
                    android:gravity="center"
                    android:minWidth="@dimen/heightsize_50dp"
                    android:layout_weight="1"
                    android:layout_height="match_parent"
                    android:layout_width="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text=""
                    android:padding="@dimen/heightsize_6dp"
                    android:background="@drawable/blue_btn"
                    android:layout_marginHorizontal="@dimen/heightsize_6dp"
                    android:fontFamily="@font/dmsans_bold"
                    android:textColor="@color/white"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/lbl_name" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:id="@+id/line6"
                android:orientation="horizontal"
                android:layout_marginTop="@dimen/_5sdp"
                android:gravity="start"
                android:layout_marginHorizontal="@dimen/heightsize_16dp"
                app:layout_constraintTop_toBottomOf="@+id/line4"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_height="wrap_content">



                <TextView
                    android:id="@+id/validity"
                    style="@style/cardlabelStyle"
                    android:layout_height="match_parent"
                    android:layout_width="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text="@string/txt_validity"
                    android:minWidth="@dimen/heightsize_60dp"
                    android:fontFamily="@font/dmsans_bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/lbl_name"
                    />

                <TextView
                    android:id="@+id/valuesvalidity"
                    style="@style/cardtextStyle"
                    android:layout_height="match_parent"
                    android:layout_width="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text=""
                    android:fontFamily="@font/dmsans_bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/lbl_name"
                    />





            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:id="@+id/line7"
                android:visibility="gone"
                android:orientation="horizontal"
                android:layout_marginTop="@dimen/_5sdp"
                android:gravity="start"
                android:layout_marginHorizontal="@dimen/heightsize_16dp"
                app:layout_constraintTop_toBottomOf="@+id/line6"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_height="wrap_content">



                <TextView
                    android:id="@+id/sms"
                    style="@style/cardlabelStyle"
                    android:layout_height="match_parent"
                    android:layout_width="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text="@string/txt_sms"
                    android:minWidth="@dimen/heightsize_60dp"
                    android:fontFamily="@font/dmsans_bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/lbl_name"
                    />

                <TextView
                    android:id="@+id/valuessms"
                    style="@style/cardtextStyle"
                    android:layout_height="match_parent"
                    android:layout_width="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text=""
                    android:fontFamily="@font/dmsans_bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/lbl_name"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:id="@+id/line5"
                android:orientation="horizontal"
                android:gravity="start"
                android:layout_marginTop="@dimen/heightsize_5dp"
                android:layout_marginHorizontal="@dimen/heightsize_16dp"
                app:layout_constraintTop_toBottomOf="@+id/line7"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_height="wrap_content">



                <TextView
                    android:id="@+id/imps"
                    style="@style/cardlabelStyle"
                    android:layout_height="match_parent"
                    android:layout_width="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text="@string/txt_details"
                    android:minWidth="@dimen/heightsize_60dp"
                    android:fontFamily="@font/dmsans_bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/lbl_name"
                    />

                <TextView
                    android:id="@+id/description"
                    style="@style/cardtextStyle"
                    android:layout_height="match_parent"
                    android:layout_width="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text=""
                    android:fontFamily="@font/dmsans_bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/lbl_name"/>





            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/heightsize_12dp"
                android:layout_marginBottom="16dp"
                android:padding="5sp"
                android:id="@+id/btn_viewdetails"
                android:layout_marginEnd="@dimen/_12sdp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/line5"
                android:gravity="center"
                android:visibility="visible">
                <TextView
                    android:id="@+id/tvtitleview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/dmsans_bold"
                    android:text="@string/txt_view_more"
                    android:textColor="@color/blue_app"
                    android:textSize="10sp" />

            </LinearLayout>

            <!--<View
                android:layout_width="wrap_content"
                android:layout_marginTop="15sp"
                android:id="@+id/view2"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/line5"
                android:background="@color/color_C7BFBF"
                android:layout_height="0.5dp">

            </View>-->

        </androidx.constraintlayout.widget.ConstraintLayout>

</layout>