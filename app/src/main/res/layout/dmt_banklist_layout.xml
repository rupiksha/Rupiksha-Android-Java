<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:paddingTop="@dimen/heightsize_12dp"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:id="@+id/line2"
                android:orientation="horizontal"
                android:weightSum="3"
                android:layout_marginHorizontal="@dimen/heightsize_16dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_height="wrap_content">


                <TextView
                    android:id="@+id/accountnumber"
                    style="@style/cardlabelStyle"
                    android:layout_width="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text="@string/lbl_account_number"
                    android:layout_weight="1"
                    app:layout_constraintStart_toStartOf="parent"
                    />

                <TextView
                    android:id="@+id/name"
                    style="@style/cardlabelStyle"
                    android:layout_width="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text="@string/lbl_name"
                    android:layout_weight="1"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/lbl_name"
                    />
                <TextView
                    android:id="@+id/bankname"
                    style="@style/cardlabelStyle"
                    android:layout_weight="1"
                    android:layout_width="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text="@string/lbl_bank_name"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/lbl_name"
                    />

<!--                <TextView-->
<!--                    android:id="@+id/action"-->
<!--                    style="@style/cardlabelStyle"-->
<!--                    android:layout_width="wrap_content"-->
<!--                    app:layout_constraintTop_toTopOf="parent"-->
<!--                    android:layout_weight="1"-->
<!--                    android:text="@string/lbl_action"-->
<!--                    app:layout_constraintEnd_toEndOf="parent"-->
<!--                    app:layout_constraintStart_toEndOf="@+id/lbl_name"-->
<!--                    />-->
            </LinearLayout>

            <View
                android:layout_width="wrap_content"
                android:layout_marginTop="15sp"
                android:id="@+id/view1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/line2"
                android:background="@color/color_C7BFBF"
                android:layout_height="0.5dp">

            </View>

            <LinearLayout
                android:layout_width="match_parent"
                android:id="@+id/line4"
                android:orientation="horizontal"
                android:layout_marginTop="@dimen/heightsize_8dp"
                android:weightSum="3"
                android:layout_marginHorizontal="@dimen/heightsize_16dp"
                app:layout_constraintTop_toBottomOf="@+id/view1"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_height="wrap_content">


                <TextView
                    android:id="@+id/valueaccountnumber"
                    style="@style/cardtextStyle"
                    android:gravity="center_vertical"
                    android:layout_height="match_parent"
                    android:layout_width="wrap_content"
                    android:ellipsize="end"
                    android:layout_weight="1"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text=""
                    app:layout_constraintStart_toStartOf="parent"
                    />

                <TextView
                    android:id="@+id/valuename"
                    style="@style/cardtextStyle"
                    android:gravity="center_vertical"
                    android:layout_height="match_parent"
                    android:layout_width="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text=""
                    android:layout_weight="1"
                    android:ellipsize="end"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/lbl_name"
                    />
                <TextView
                    android:id="@+id/valuebankname"
                    style="@style/cardtextStyle"
                    android:gravity="center_vertical"
                    android:layout_height="match_parent"
                    android:layout_width="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text=""
                    android:ellipsize="end"
                    android:singleLine="true"
                    android:maxLines="10"
                    android:layout_weight="1"
                    android:fontFamily="@font/dmsans_bold"
                    android:textColor="@color/color_259A2A"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/lbl_name"
                    />

<!--                <ImageView-->
<!--                    android:id="@+id/valueaction"-->
<!--                    style="@style/cardtextStyle"-->
<!--                    android:gravity="center_vertical"-->
<!--                    android:layout_height="match_parent"-->
<!--                    android:layout_gravity="center"-->
<!--                    android:layout_width="wrap_content"-->
<!--                    app:layout_constraintTop_toTopOf="parent"-->
<!--                    android:src="@drawable/delete"-->
<!--                    android:layout_weight=".5"-->
<!--                    app:layout_constraintEnd_toEndOf="parent"-->
<!--                    app:layout_constraintStart_toEndOf="@+id/lbl_name"-->

<!--                    />-->

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:id="@+id/line5"
                android:orientation="horizontal"
                android:gravity="end"
                android:layout_marginTop="@dimen/heightsize_10dp"
                android:layout_marginHorizontal="@dimen/heightsize_16dp"
                app:layout_constraintTop_toBottomOf="@+id/line4"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/imps"
                    style="@style/cardtextStyle"
                    android:layout_height="match_parent"
                    android:layout_width="100dp"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text="@string/txt_imps"
                    android:gravity="center"
                    android:minWidth="@dimen/heightsize_50dp"
                    android:padding="@dimen/heightsize_6dp"
                    android:background="@drawable/blue_btn"
                    android:layout_marginHorizontal="@dimen/heightsize_6dp"
                    android:fontFamily="@font/dmsans_bold"
                    android:textColor="@color/white"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/lbl_name"
                    />

                <TextView
                    android:id="@+id/neft"
                    style="@style/cardtextStyle"
                    android:gravity="center"
                    android:minWidth="@dimen/heightsize_50dp"
                    android:layout_height="match_parent"
                    android:layout_width="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text="@string/txt_neft"
                    android:padding="@dimen/heightsize_6dp"
                    android:visibility="gone"
                    android:background="@drawable/blue_btn"
                    android:layout_marginHorizontal="@dimen/heightsize_12dp"
                    android:fontFamily="@font/dmsans_bold"
                    android:textColor="@color/white"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/lbl_name"
                    />

            </LinearLayout>
            <View
                android:layout_width="wrap_content"
                android:layout_marginTop="15sp"
                android:id="@+id/view2"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/line5"
                android:background="@color/color_C7BFBF"
                android:layout_height="0.5dp">

            </View>


        </androidx.constraintlayout.widget.ConstraintLayout>




</layout>