<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/color_F5EBEB">

        <LinearLayout
            android:id="@+id/llSimmer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/white"
            android:orientation="vertical">

            <com.facebook.shimmer.ShimmerFrameLayout
                android:id="@+id/sflMyTrips"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/white"
                android:visibility="visible"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/textView3">

                <include layout="@layout/shimmer_fragment_support" />

            </com.facebook.shimmer.ShimmerFrameLayout>

        </LinearLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/swipeToRefresh"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/color_F5EBEB">

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:fillViewport="true"
                android:scrollbars="none"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:context=".fragments.HomeFragment">

                    <ImageView
                        android:id="@+id/image"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginVertical="30sp"
                        android:fontFamily="@font/dmsans_bold"
                        android:src="@drawable/group_277"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/lbl_support"
                        style="@style/labelStyle"
                        android:layout_width="wrap_content"
                        android:layout_marginTop="@dimen/heightsize_16dp"
                        android:text="@string/label_contact"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/image" />


                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/materialcard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="@dimen/_16sdp"
                        android:layout_marginTop="@dimen/heightsize_16dp"
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="@dimen/_10sdp"
                        app:cardElevation="@dimen/heightsize_6dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/lbl_support">


                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:paddingTop="@dimen/_16sdp"
                            android:paddingBottom="@dimen/heightsize_32dp">

                            <androidx.constraintlayout.widget.ConstraintLayout
                                android:id="@+id/line2"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginHorizontal="@dimen/heightsize_16dp"
                                android:layout_marginTop="10sp"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent">


                                <TextView
                                    android:id="@+id/lbl_mobile"
                                    style="@style/labelStyle"
                                    android:layout_width="wrap_content"
                                    android:minWidth="130sp"
                                    android:text="@string/label_mobile_number"
                                    app:layout_constraintStart_toStartOf="parent"

                                    app:layout_constraintTop_toTopOf="parent" />

                                <TextView
                                    android:id="@+id/mobile"
                                    style="@style/viewtextStyle"
                                    android:layout_width="0dp"
                                    android:minWidth="100sp"
                                    android:text=""
                                    app:layout_constraintEnd_toEndOf="parent"
                                    app:layout_constraintStart_toEndOf="@+id/lbl_mobile"
                                    app:layout_constraintTop_toTopOf="parent" />

                                <View
                                    android:layout_width="wrap_content"
                                    android:layout_height="0.5dp"
                                    android:layout_marginTop="10sp"
                                    android:background="@color/color_C7BFBF"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toBottomOf="@+id/mobile">

                                </View>

                            </androidx.constraintlayout.widget.ConstraintLayout>

                            <androidx.constraintlayout.widget.ConstraintLayout
                                android:id="@+id/line3"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginHorizontal="@dimen/heightsize_16dp"
                                android:layout_marginTop="10sp"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toBottomOf="@+id/line2">


                                <TextView
                                    android:id="@+id/lbl_email"
                                    style="@style/labelStyle"
                                    android:layout_width="wrap_content"
                                    android:minWidth="130sp"
                                    android:text="@string/label_email"
                                    app:layout_constraintStart_toStartOf="parent"

                                    app:layout_constraintTop_toTopOf="parent" />

                                <TextView
                                    android:id="@+id/email"
                                    style="@style/viewtextStyle"
                                    android:layout_width="0dp"
                                    android:minWidth="100sp"
                                    android:text=""
                                    app:layout_constraintEnd_toEndOf="parent"
                                    app:layout_constraintStart_toEndOf="@+id/lbl_email"
                                    app:layout_constraintTop_toTopOf="parent" />

                                <View
                                    android:layout_width="wrap_content"
                                    android:layout_height="0.5dp"
                                    android:layout_marginTop="10sp"
                                    android:background="@color/color_C7BFBF"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toBottomOf="@+id/email">

                                </View>

                            </androidx.constraintlayout.widget.ConstraintLayout>


                            <androidx.constraintlayout.widget.ConstraintLayout
                                android:id="@+id/line6"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginHorizontal="@dimen/heightsize_16dp"
                                android:layout_marginTop="10sp"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toBottomOf="@+id/line3">


                                <TextView
                                    android:id="@+id/lbl_address"
                                    style="@style/labelStyle"
                                    android:layout_width="wrap_content"
                                    android:minWidth="130sp"
                                    android:text="@string/label_address"
                                    app:layout_constraintStart_toStartOf="parent"

                                    app:layout_constraintTop_toTopOf="parent" />

                                <TextView
                                    android:id="@+id/address"
                                    style="@style/viewtextStyle"
                                    android:layout_width="0dp"
                                    android:minWidth="100sp"
                                    android:text=""
                                    app:layout_constraintEnd_toEndOf="parent"
                                    app:layout_constraintStart_toEndOf="@+id/lbl_address"
                                    app:layout_constraintTop_toTopOf="parent" />

                                <View
                                    android:layout_width="wrap_content"
                                    android:layout_height="0.5dp"
                                    android:layout_marginTop="10sp"
                                    android:background="@color/color_C7BFBF"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toBottomOf="@+id/address">

                                </View>

                            </androidx.constraintlayout.widget.ConstraintLayout>


                        </androidx.constraintlayout.widget.ConstraintLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <View
                        android:id="@+id/view1"
                        android:layout_width="wrap_content"
                        android:layout_height="0.5dp"
                        android:layout_marginTop="@dimen/heightsize_24dp"
                        android:background="@color/color_C7BFBF"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/materialcard">

                    </View>

                    <LinearLayout
                        android:id="@+id/llayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="5sp"
                        android:background="@color/white"
                        android:gravity="center_horizontal"
                        android:orientation="horizontal"

                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/view1">

                        <ImageView
                            android:id="@+id/watsapp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginVertical="30dp"
                            android:contentDescription="@string/app_name"
                            android:padding="@dimen/_10sdp"
                            android:src="@drawable/whatsapp" />

                        <ImageView
                            android:id="@+id/instagram"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginVertical="30dp"
                            android:layout_marginStart="16sp"
                            android:contentDescription="@string/app_name"
                            android:padding="@dimen/_10sdp"
                            android:src="@drawable/insta" />


                        <ImageView
                            android:id="@+id/facebook"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginVertical="30dp"
                            android:layout_marginStart="16sp"
                            android:contentDescription="@string/app_name"
                            android:padding="@dimen/_10sdp"
                            android:src="@drawable/fb" />

                        <ImageView
                            android:id="@+id/twitter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginVertical="30dp"
                            android:layout_marginStart="16sp"
                            android:contentDescription="@string/app_name"
                            android:padding="@dimen/_10sdp"
                            android:src="@drawable/tweet" />

                        <ImageView
                            android:id="@+id/linkedin"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginVertical="30dp"
                            android:layout_marginStart="16sp"
                            android:contentDescription="@string/app_name"
                            android:padding="@dimen/_10sdp"
                            android:src="@drawable/linkden" />


                    </LinearLayout>

                    <View
                        android:id="@+id/view2"
                        android:layout_width="wrap_content"
                        android:layout_height="0.5dp"
                        android:background="@color/color_C7BFBF"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/llayout" />


                </androidx.constraintlayout.widget.ConstraintLayout>


            </androidx.core.widget.NestedScrollView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </RelativeLayout>
</layout>