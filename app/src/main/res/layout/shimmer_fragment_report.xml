<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/swipeToRefresh"
        android:layout_width="match_parent"
        android:background="@color/white"
        android:layout_height="match_parent">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:fillViewport="true"
            android:scrollbars="none"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                tools:context=".fragments.HomeFragment">



                <TextView
                    android:id="@+id/lbl_support"
                    android:layout_height="wrap_content"
                    android:layout_width="@dimen/_100sdp"
                    android:layout_marginTop="@dimen/heightsize_24dp"
                    app:layout_constraintTop_toTopOf="parent"
                    android:background="@color/color_C5C5C5"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/cc_1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toBottomOf="@+id/lbl_support"
                    android:layout_marginTop="@dimen/_20sdp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="@dimen/_80sdp"
                        android:id="@+id/materialcard1"
                        app:cardElevation="@dimen/heightsize_3dp"
                        android:layout_marginVertical="@dimen/heightsize_10dp"
                        android:layout_marginStart="@dimen/_10sdp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:cardBackgroundColor="@color/color_C5C5C5"
                        app:cardCornerRadius="@dimen/_10sdp"
                        android:layout_height="@dimen/_85sdp">


                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="@dimen/_80sdp"
                        android:id="@+id/materialcard2"
                        app:cardElevation="@dimen/heightsize_3dp"
                        android:layout_marginVertical="@dimen/heightsize_10dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:cardBackgroundColor="@color/color_C5C5C5"
                        app:cardCornerRadius="@dimen/_10sdp"
                        android:layout_height="@dimen/_85sdp">

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="@dimen/_80sdp"
                        android:id="@+id/materialcard3"
                        app:cardElevation="@dimen/heightsize_3dp"
                        android:layout_marginEnd="@dimen/_10sdp"
                        android:layout_marginVertical="@dimen/heightsize_10dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:cardBackgroundColor="@color/color_C5C5C5"
                        app:cardCornerRadius="@dimen/_10sdp"
                        android:layout_height="@dimen/_85sdp">

                    </com.google.android.material.card.MaterialCardView>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/cc_2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toBottomOf="@+id/cc_1"
                    android:layout_marginTop="@dimen/_20sdp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="@dimen/_80sdp"
                        android:id="@+id/materialcard4"
                        app:cardElevation="@dimen/heightsize_3dp"
                        android:layout_marginStart="@dimen/_10sdp"
                        android:layout_marginVertical="@dimen/heightsize_10dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:cardBackgroundColor="@color/color_C5C5C5"
                        app:cardCornerRadius="@dimen/_10sdp"
                        android:layout_height="@dimen/_85sdp">


                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="@dimen/_80sdp"
                        android:id="@+id/materialcard5"
                        app:cardElevation="@dimen/heightsize_3dp"
                        android:layout_marginVertical="@dimen/heightsize_10dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:cardBackgroundColor="@color/color_C5C5C5"
                        app:cardCornerRadius="@dimen/_10sdp"
                        android:layout_height="@dimen/_85sdp">

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="@dimen/_80sdp"
                        android:id="@+id/materialcard6"
                        app:cardElevation="@dimen/heightsize_3dp"
                        android:layout_marginEnd="@dimen/_10sdp"
                        android:layout_marginVertical="@dimen/heightsize_10dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:cardBackgroundColor="@color/color_C5C5C5"
                        app:cardCornerRadius="@dimen/_10sdp"
                        android:layout_height="@dimen/_85sdp">

                    </com.google.android.material.card.MaterialCardView>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/cc_3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toBottomOf="@+id/cc_2"
                    android:layout_marginTop="@dimen/_20sdp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="@dimen/_80sdp"
                        android:id="@+id/materialcard7"
                        app:cardElevation="@dimen/heightsize_3dp"
                        android:layout_marginStart="@dimen/_10sdp"
                        android:layout_marginVertical="@dimen/heightsize_10dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:cardBackgroundColor="@color/color_C5C5C5"
                        app:cardCornerRadius="@dimen/_10sdp"
                        android:layout_height="@dimen/_85sdp">


                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="@dimen/_80sdp"
                        android:id="@+id/materialcard8"
                        app:cardElevation="@dimen/heightsize_3dp"
                        android:layout_marginVertical="@dimen/heightsize_10dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:cardBackgroundColor="@color/color_C5C5C5"
                        app:cardCornerRadius="@dimen/_10sdp"
                        android:layout_height="@dimen/_85sdp">

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="@dimen/_80sdp"
                        android:id="@+id/materialcard9"
                        app:cardElevation="@dimen/heightsize_3dp"
                        android:layout_marginEnd="@dimen/_10sdp"
                        android:layout_marginVertical="@dimen/heightsize_10dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:cardBackgroundColor="@color/color_C5C5C5"
                        app:cardCornerRadius="@dimen/_10sdp"
                        android:layout_height="@dimen/_85sdp">

                    </com.google.android.material.card.MaterialCardView>
                </androidx.constraintlayout.widget.ConstraintLayout>


            </androidx.constraintlayout.widget.ConstraintLayout>


        </androidx.core.widget.NestedScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>