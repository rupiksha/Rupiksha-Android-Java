<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/color_F5EBEB">

        <include
            android:id="@+id/includeLayout"
            layout="@layout/toolbar_metarial_design">

        </include>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/svLogin"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:fillViewport="true"
            android:scrollbars="none"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/includeLayout">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/llRootLayout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingBottom="@dimen/_20sdp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:focusableInTouchMode="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="230dp"
                    android:id="@+id/image"
                    android:layout_height="@dimen/heightsize_100dp"
                    android:layout_gravity="center"
                    android:fontFamily="@font/dmsans_bold"
                    android:src="@drawable/logo"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"

                    android:paddingStart="16sp" />


                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:id="@+id/materialcard"
                    app:cardElevation="@dimen/heightsize_6dp"
                    app:layout_constraintTop_toBottomOf="@+id/image"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginTop="@dimen/heightsize_16dp"
                    android:layout_marginHorizontal="@dimen/_16sdp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="@dimen/_10sdp"
                    android:layout_height="wrap_content">


                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:paddingTop="@dimen/_10sdp"
                        android:paddingBottom="@dimen/heightsize_16dp"
                        android:layout_height="match_parent">


                        <TextView
                            android:id="@+id/tvtitle"
                            style="@style/TitleStyle"
                            app:layout_constraintTop_toTopOf="parent"
                            android:text="@string/text_recharge_title"
                            android:layout_marginHorizontal="@dimen/_16sdp"
                            android:gravity="center"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent" />


                        <View
                            android:id="@+id/viewLineOne"
                            android:layout_width="130sp"
                            android:layout_height="0.3dp"
                            app:layout_constraintTop_toBottomOf="@+id/tvtitle"
                            app:layout_constraintStart_toStartOf="parent"
                            android:layout_marginHorizontal="@dimen/heightsize_32dp"
                            app:layout_constraintEnd_toEndOf="parent"
                            android:layout_marginTop="@dimen/heightsize_10dp"
                            android:layout_marginBottom="@dimen/heightsize_16dp"
                            android:background="@color/blue_app"
                            android:visibility="visible"/>



                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilmobilenumber"
                            style="@style/TextInputLayoutStyle"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginHorizontal="@dimen/heightsize_16dp"
                            android:layout_marginTop="@dimen/heightsize_16dp"
                            android:hint="@string/lbl_user_name"
                            app:layout_constraintTop_toBottomOf="@+id/viewLineOne"
                            app:placeholderText="@string/placeholder_text_mobile_no">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etmobilenumber"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/heightsize_60dp"
                                android:fontFamily="@font/dmsans_regular"
                                android:imeOptions="actionNext"
                                android:textCursorDrawable="@drawable/cursor"
                                android:inputType="number"
                                />
                        </com.google.android.material.textfield.TextInputLayout>






                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/timinduration"
                            style="@style/dropdown"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="@dimen/heightsize_16dp"
                            android:layout_marginTop="@dimen/heightsize_15dp"
                            android:layout_weight="1" app:hintEnabled="false"
                            app:layout_constraintTop_toBottomOf="@+id/tilmobilenumber">

                            <AutoCompleteTextView
                                android:id="@+id/etbank"
                                android:layout_width="match_parent"
                                android:layout_height="56dp"
                                android:background="@drawable/drawable_edit_text_bg"
                                android:baselineAligned="false"
                                android:drawableRight="@drawable/drop"
                                android:hint="@string/lbl_select_operator"
                                android:paddingHorizontal="@dimen/heightsize_11dp"
                                android:imeOptions="actionNext"
                                android:inputType="none"
                                android:textColor="@color/black"
                                android:textColorHint="@color/white_60"
                                android:textCursorDrawable="@drawable/cursor"/>

                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilamount"
                            style="@style/TextInputLayoutStyle"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginHorizontal="@dimen/heightsize_16dp"
                            android:layout_marginTop="@dimen/heightsize_10dp"
                            android:hint="@string/lbl_enter_amount"
                            android:visibility="visible"
                            app:layout_constraintTop_toBottomOf="@+id/timinduration"
                            app:placeholderText="@string/placeholder_amount">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etamount"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/heightsize_60dp"
                                android:fontFamily="@font/dmsans_regular"
                                android:imeOptions="actionNext"
                                android:drawableLeft="@drawable/rupees"
                                android:drawablePadding="@dimen/heightsize_5dp"
                                android:textCursorDrawable="@drawable/cursor"
                                android:inputType="number"
                                />
                        </com.google.android.material.textfield.TextInputLayout>




                    </androidx.constraintlayout.widget.ConstraintLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnvieplan"
                    style="@style/ThemeAppButton"
                    android:backgroundTint="@color/blue_app"
                    android:layout_marginTop="@dimen/heightsize_16dp"
                    android:visibility="gone"
                    app:layout_constraintTop_toBottomOf="@+id/materialcard"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:text="@string/btn_text_view_plan" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnpaynow"
                    style="@style/ThemeAppButton"
                    android:visibility="visible"
                    android:backgroundTint="@color/color_F72F20"
                    android:layout_marginTop="@dimen/heightsize_5dp"
                    app:layout_constraintTop_toBottomOf="@+id/btnvieplan"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:text="@string/btn_paynow" />


                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/lltransactionLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:layout_marginTop="@dimen/heightsize_12dp"
                    android:orientation="vertical"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/btnpaynow"
                    android:focusableInTouchMode="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/transactiontitle"
                        style="@style/labelStyle"
                        android:layout_width="wrap_content"
                        app:layout_constraintTop_toTopOf="parent"
                        android:text="@string/lbl_transation_title"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/fetchbillrecycler"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:layout_marginTop="@dimen/heightsize_16dp"
                        android:overScrollMode="never"
                        android:clipToPadding="false"
                        android:paddingBottom="@dimen/heightsize_16dp"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        tools:listitem="@layout/fetch_recharge_layout" />


                </androidx.constraintlayout.widget.ConstraintLayout>


            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.core.widget.NestedScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>


