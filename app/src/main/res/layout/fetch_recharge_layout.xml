<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">


    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:id="@+id/materialcard"
        app:cardElevation="@dimen/heightsize_6dp"
        app:layout_constraintTop_toBottomOf="@+id/image"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="@dimen/heightsize_16dp"
        android:layout_marginHorizontal="@dimen/heightsize_16dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="@dimen/_10sdp"
        android:layout_height="wrap_content">


        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:paddingTop="@dimen/heightsize_12dp"
            android:paddingBottom="@dimen/heightsize_12dp"
            android:layout_height="match_parent">



            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:id="@+id/line1"
                android:layout_marginHorizontal="@dimen/heightsize_16dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_height="wrap_content">


                <TextView
                    android:id="@+id/lbl_id"
                    style="@style/cardlabelStyle"
                    android:minWidth="130sp"
                    android:layout_width="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text="@string/label_mobile_number"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:id="@+id/mobile"
                    style="@style/cardtextStyle"
                    android:minWidth="100sp"
                    android:layout_width="0dp"
                    android:gravity="end"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text=""
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/lbl_id"
                    />

                <View
                    android:layout_width="wrap_content"
                    android:layout_marginTop="7sp"
                    android:visibility="invisible"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/mobile"
                    android:background="@color/color_C7BFBF"
                    android:layout_height="0.5dp">

                </View>

            </androidx.constraintlayout.widget.ConstraintLayout>


            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:id="@+id/line5"
                android:layout_marginHorizontal="@dimen/heightsize_16dp"
                app:layout_constraintTop_toBottomOf="@+id/line1"

                app:layout_constraintStart_toStartOf="parent"
                android:layout_height="wrap_content">


                <TextView
                    android:id="@+id/lbl_date"
                    style="@style/cardlabelStyle"
                    android:minWidth="130sp"
                    android:layout_width="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text="@string/lbl_date"

                    app:layout_constraintStart_toStartOf="parent"
                    />

                <TextView
                    android:id="@+id/date"
                    style="@style/cardtextStyle"
                    android:minWidth="100sp"
                    android:layout_width="0dp"
                    android:gravity="end"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text=""
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/lbl_date"
                    />

                <View
                    android:layout_width="wrap_content"
                    android:layout_marginTop="7sp"
                    android:visibility="invisible"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/date"
                    android:background="@color/color_C7BFBF"
                    android:layout_height="0.5dp">

                </View>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:id="@+id/line4"
                android:layout_marginHorizontal="@dimen/heightsize_16dp"
                app:layout_constraintTop_toBottomOf="@+id/line5"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_height="wrap_content">


                <TextView
                    android:id="@+id/lbl_amount"
                    style="@style/cardlabelStyle"
                    android:minWidth="130sp"
                    android:layout_width="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text="@string/lbl_amount"

                    app:layout_constraintStart_toStartOf="parent"
                    />

                <TextView
                    android:id="@+id/amount"
                    style="@style/cardtextStyle"
                    android:minWidth="100sp"
                    android:layout_width="0dp"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text=""
                    android:gravity="end"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/lbl_amount"
                    />

                <View
                    android:layout_width="wrap_content"
                    android:layout_marginTop="7sp"
                    android:visibility="invisible"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/amount"
                    android:background="@color/color_C7BFBF"
                    android:layout_height="0.5dp">
                </View>

            </androidx.constraintlayout.widget.ConstraintLayout>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:id="@+id/line6"
                android:layout_marginHorizontal="@dimen/heightsize_16dp"
                app:layout_constraintTop_toBottomOf="@+id/line4"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_height="wrap_content">


                <TextView
                    android:id="@+id/lbl_status"
                    style="@style/cardlabelStyle"
                    android:minWidth="130sp"
                    android:layout_width="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text="@string/lbl_status"

                    app:layout_constraintStart_toStartOf="parent"
                    />

                <TextView
                    android:id="@+id/status"
                    style="@style/cardtextStyle"
                    android:minWidth="100sp"
                    android:layout_width="0dp"
                    android:gravity="end"
                    android:textColor="@color/color_259A2A"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text=""
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/lbl_status"
                    />

                <View
                    android:layout_width="wrap_content"
                    android:layout_marginTop="7sp"
                    android:visibility="invisible"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/status"
                    android:background="@color/color_C7BFBF"
                    android:layout_height="0.5dp">

                </View>

            </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:id="@+id/viewmorelayout"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@+id/line6"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_height="wrap_content">



            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:id="@+id/line3"
                android:layout_marginHorizontal="@dimen/heightsize_16dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_height="wrap_content">


                <TextView
                    android:id="@+id/lbl_txid"
                    style="@style/cardlabelStyle"
                    android:minWidth="130sp"
                    android:layout_width="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text="@string/lbl_tx_id"

                    app:layout_constraintStart_toStartOf="parent"
                    />

                <TextView
                    android:id="@+id/tx_id"
                    style="@style/cardtextStyle"
                    android:minWidth="100sp"
                    android:layout_width="0dp"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text="ECZN42458956"
                    android:gravity="end"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/lbl_txid"
                    />

                <View
                    android:layout_width="wrap_content"
                    android:layout_marginTop="7sp"
                    android:visibility="invisible"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tx_id"
                    android:background="@color/color_C7BFBF"
                    android:layout_height="0.5dp">

                </View>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:id="@+id/line7"
                android:layout_marginHorizontal="@dimen/heightsize_16dp"
                app:layout_constraintTop_toBottomOf="@+id/line3"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_height="wrap_content">


                <TextView
                    android:id="@+id/lbl_op_name"
                    style="@style/cardlabelStyle"
                    android:minWidth="130sp"
                    android:layout_width="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text="@string/lbl_operator_name"
                    app:layout_constraintStart_toStartOf="parent"
                    />

                <TextView
                    android:id="@+id/operator_name"
                    style="@style/cardtextStyle"
                    android:minWidth="100sp"
                    android:layout_width="0dp"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text="Jio"
                    android:gravity="end"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/lbl_op_name"
                    />

                <View
                    android:layout_width="wrap_content"
                    android:layout_marginTop="7sp"
                    android:visibility="gone"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/operator_name"
                    android:background="@color/color_C7BFBF"
                    android:layout_height="0.5dp">

                </View>

            </androidx.constraintlayout.widget.ConstraintLayout>






        </androidx.constraintlayout.widget.ConstraintLayout>


            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/heightsize_12dp"
                android:layout_marginBottom="16dp"
                android:padding="5sp"
                android:id="@+id/btn_viewdetails"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/viewmorelayout"
                android:gravity="center"
                android:visibility="visible"
                android:onClick="onClick">
                <TextView
                    android:id="@+id/tvtitleview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/dmsans_bold"
                    android:text="@string/txt_view_more"
                    android:textColor="@color/blue_app"
                    android:textSize="10sp" />

                <ImageView
                    android:id="@+id/ivpaymentview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:contentDescription="@string/app_name"
                    android:paddingHorizontal="@dimen/heightsize_3dp"
                    android:layout_marginEnd="@dimen/heightsize_13dp"
                    android:src="@drawable/view_less"
                    android:visibility="visible" />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>



    </com.google.android.material.card.MaterialCardView>


</layout>