<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">


    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:id="@+id/materialcard"
        app:cardElevation="@dimen/heightsize_2dp"
        android:layout_marginVertical="@dimen/heightsize_5dp"
        app:layout_constraintTop_toBottomOf="@+id/image"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="@dimen/heightsize_10dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="@dimen/_10sdp"
        android:layout_height="wrap_content">


        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:paddingTop="@dimen/heightsize_12dp"
            android:paddingBottom="@dimen/heightsize_12dp"
            android:layout_height="match_parent">



            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:id="@+id/line1"
                android:layout_marginHorizontal="@dimen/heightsize_16dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_height="wrap_content">


                <TextView
                    android:id="@+id/lbl_id"
                    style="@style/cardlabelStyle"
                    android:minWidth="130sp"
                    android:layout_width="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text="@string/lbl_account_no"

                    app:layout_constraintStart_toStartOf="parent"
                    />

                <TextView
                    android:id="@+id/account"
                    style="@style/cardtextStyle"
                    android:minWidth="100sp"
                    android:layout_width="0dp"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text=""
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/lbl_id"
                    />

                <View
                    android:layout_width="wrap_content"
                    android:layout_marginTop="7sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/account"
                    android:background="@color/color_C7BFBF"
                    android:layout_height="0.5dp">

                </View>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:id="@+id/line2"
                android:layout_marginHorizontal="@dimen/heightsize_16dp"
                app:layout_constraintTop_toBottomOf="@+id/line1"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_height="wrap_content">


                <TextView
                    android:id="@+id/lbl_name"
                    style="@style/cardlabelStyle"
                    android:minWidth="130sp"
                    android:layout_width="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text="@string/lbl_name"

                    app:layout_constraintStart_toStartOf="parent"
                    />

                <TextView
                    android:id="@+id/name"
                    style="@style/cardtextStyle"
                    android:minWidth="100sp"
                    android:layout_width="0dp"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text=""
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/lbl_name"
                    />

                <View
                    android:layout_width="wrap_content"
                    android:layout_marginTop="7sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/name"
                    android:background="@color/color_C7BFBF"
                    android:layout_height="0.5dp">

                </View>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:id="@+id/line3"
                android:layout_marginHorizontal="@dimen/heightsize_16dp"
                app:layout_constraintTop_toBottomOf="@+id/line2"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_height="wrap_content">


                <TextView
                    android:id="@+id/lbl_txid"
                    style="@style/cardlabelStyle"
                    android:minWidth="130sp"
                    android:layout_width="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text="@string/lbl_ifsc_code"

                    app:layout_constraintStart_toStartOf="parent"
                    />

                <TextView
                    android:id="@+id/tx_ifsc"
                    style="@style/cardtextStyle"
                    android:minWidth="100sp"
                    android:layout_width="0dp"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text=""
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/lbl_txid"
                    />

                <View
                    android:layout_width="wrap_content"
                    android:layout_marginTop="7sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tx_ifsc"
                    android:background="@color/color_C7BFBF"
                    android:layout_height="0.5dp">

                </View>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:id="@+id/line4"
                android:layout_marginHorizontal="@dimen/heightsize_16dp"
                app:layout_constraintTop_toBottomOf="@+id/line3"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_height="wrap_content">


                <TextView
                    android:id="@+id/lbl_amount"
                    style="@style/cardlabelStyle"
                    android:minWidth="130sp"
                    android:layout_width="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text="@string/lbl_bank"

                    app:layout_constraintStart_toStartOf="parent"
                    />

                <TextView
                    android:id="@+id/bank"
                    style="@style/cardtextStyle"
                    android:minWidth="100sp"
                    android:layout_width="0dp"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text=""
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/lbl_amount"
                    />

                <View
                    android:layout_width="wrap_content"
                    android:layout_marginTop="7sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/bank"
                    android:background="@color/color_C7BFBF"
                    android:layout_height="0.5dp">

                </View>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:id="@+id/line5"
                android:layout_marginHorizontal="@dimen/heightsize_16dp"
                app:layout_constraintTop_toBottomOf="@+id/line4"
                android:layout_marginTop="5sp"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/imps"
                    style="@style/cardtextStyle"
                    android:layout_height="match_parent"
                    android:layout_width="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="@+id/valueaction"
                    android:text="@string/txt_select"
                    android:gravity="center"
                    android:minWidth="@dimen/heightsize_50dp"

                    android:paddingHorizontal="@dimen/heightsize_15dp"
                    android:paddingVertical="@dimen/heightsize_6dp"
                    android:background="@drawable/blue_btn"
                    android:layout_marginHorizontal="@dimen/heightsize_6dp"
                    android:fontFamily="@font/dmsans_bold"
                    android:textColor="@color/white"

                    app:layout_constraintEnd_toStartOf="@+id/valueaction"

                    />

                <ImageView
                    android:id="@+id/valueaction"
                    style="@style/cardtextStyle"
                    android:layout_weight="1"
                    android:visibility="invisible"
                    android:gravity="center_vertical"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:layout_width="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    android:src="@drawable/delete"
                    app:layout_constraintStart_toEndOf="@+id/imps"
                    app:layout_constraintEnd_toEndOf="parent"

                    />

                <View
                    android:layout_width="wrap_content"
                    android:visibility="gone"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/valueaction"
                    android:background="@color/color_C7BFBF"
                    android:layout_height="0.5dp">

                </View>

            </androidx.constraintlayout.widget.ConstraintLayout>







        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>


</layout>