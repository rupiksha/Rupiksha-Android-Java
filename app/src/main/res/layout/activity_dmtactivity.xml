<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/color_F5EBEB">

        <include
            android:id="@+id/includeLayout"
            layout="@layout/toolbar_metarial_design">

        </include>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/svLogin"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:fillViewport="true"
            android:scrollbars="none"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/includeLayout">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/llRootLayout"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:orientation="vertical"

                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:focusableInTouchMode="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="230dp"
                    android:id="@+id/image"
                    android:layout_height="@dimen/heightsize_100dp"
                    android:layout_gravity="center"
                    android:fontFamily="@font/dmsans_bold"
                    android:src="@drawable/logo"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:paddingStart="16sp" />


                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:id="@+id/materialcard"
                    app:cardElevation="@dimen/heightsize_6dp"
                    app:layout_constraintTop_toBottomOf="@+id/image"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginTop="@dimen/heightsize_16dp"
                    android:layout_marginHorizontal="@dimen/_16sdp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="@dimen/_10sdp"
                    android:layout_height="wrap_content">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:paddingTop="@dimen/_16sdp"
                        android:paddingBottom="@dimen/heightsize_32dp"
                        android:layout_height="match_parent">

                        <TextView
                            android:id="@+id/tvtitle"
                            style="@style/TitleStyle"
                            app:layout_constraintTop_toTopOf="parent"
                            android:text="@string/text_balance_enquiry_title"
                            android:layout_marginHorizontal="@dimen/_16sdp"
                            android:gravity="center"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent" />

                        <View
                            android:id="@+id/viewLineOne"
                            android:layout_width="@dimen/heightsize_150dp"
                            android:layout_height="0.3dp"
                            app:layout_constraintTop_toBottomOf="@+id/tvtitle"
                            app:layout_constraintStart_toStartOf="parent"
                            android:layout_marginHorizontal="@dimen/heightsize_32dp"
                            app:layout_constraintEnd_toEndOf="parent"
                            android:layout_marginTop="@dimen/heightsize_10dp"
                            android:layout_marginBottom="@dimen/heightsize_16dp"
                            android:background="@color/blue_app"
                            android:visibility="visible"/>


                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:id="@+id/line1"
                            android:layout_marginHorizontal="@dimen/heightsize_16dp"
                            android:layout_marginTop="@dimen/heightsize_10dp"
                            android:visibility="gone"
                            app:layout_constraintTop_toBottomOf="@+id/viewLineOne"
                            app:layout_constraintStart_toStartOf="parent"
                            android:layout_height="wrap_content">


                            <TextView
                                android:id="@+id/lbl_name"
                                style="@style/labelStyle"
                                android:minWidth="130sp"
                                android:layout_width="wrap_content"
                                app:layout_constraintTop_toTopOf="parent"
                                android:text="@string/label_name"
                                app:layout_constraintStart_toStartOf="parent"
                                />

                            <TextView
                                android:id="@+id/name"
                                style="@style/viewtextStyle"
                                android:minWidth="100sp"
                                android:layout_width="0dp"
                                app:layout_constraintTop_toTopOf="parent"
                                android:text=""
                                android:gravity="end"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toEndOf="@+id/lbl_name"
                                />

                            <View
                                android:layout_width="wrap_content"
                                android:layout_marginTop="10sp"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toBottomOf="@+id/name"
                                android:background="@color/color_C7BFBF"
                                android:layout_height="0.5dp">

                            </View>

                        </androidx.constraintlayout.widget.ConstraintLayout>

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:id="@+id/line2"
                            android:layout_marginHorizontal="@dimen/heightsize_16dp"
                            app:layout_constraintTop_toBottomOf="@+id/line1"
                            android:layout_marginTop="10sp"
                            app:layout_constraintStart_toStartOf="parent"
                            android:layout_height="wrap_content">


                            <TextView
                                android:id="@+id/lbl_mobile"
                                style="@style/labelStyle"
                                android:minWidth="130sp"
                                android:layout_width="wrap_content"
                                app:layout_constraintTop_toTopOf="parent"
                                android:text="@string/label_mobile_number"

                                app:layout_constraintStart_toStartOf="parent"
                                />

                            <TextView
                                android:id="@+id/mobile"
                                style="@style/viewtextStyle"
                                android:minWidth="100sp"
                                android:layout_width="0dp"
                                app:layout_constraintTop_toTopOf="parent"
                                android:text=""
                                android:gravity="end"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toEndOf="@+id/lbl_mobile"
                                />

                            <View
                                android:layout_width="wrap_content"
                                android:layout_marginTop="10sp"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toBottomOf="@+id/mobile"
                                android:background="@color/color_C7BFBF"
                                android:layout_height="0.5dp">

                            </View>

                        </androidx.constraintlayout.widget.ConstraintLayout>

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:id="@+id/line3"
                            android:layout_marginHorizontal="@dimen/heightsize_16dp"
                            app:layout_constraintTop_toBottomOf="@+id/line2"
                            android:layout_marginTop="10sp"
                            android:visibility="gone"
                            app:layout_constraintStart_toStartOf="parent"
                            android:layout_height="wrap_content">


                            <TextView
                                android:id="@+id/lbl_email"
                                style="@style/labelStyle"
                                android:minWidth="130sp"
                                android:layout_width="wrap_content"
                                app:layout_constraintTop_toTopOf="parent"
                                android:text="@string/label_txn_limit"

                                app:layout_constraintStart_toStartOf="parent"
                                />

                            <TextView
                                android:id="@+id/txnlimit"
                                style="@style/viewtextStyle"
                                android:minWidth="100sp"
                                android:layout_width="0dp"
                                app:layout_constraintTop_toTopOf="parent"
                                android:text="₹ 75000"
                                android:gravity="end"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toEndOf="@+id/lbl_email"
                                />

                            <View
                                android:layout_width="wrap_content"
                                android:layout_marginTop="10sp"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toBottomOf="@+id/txnlimit"
                                android:background="@color/color_C7BFBF"
                                android:layout_height="0.5dp">

                            </View>

                        </androidx.constraintlayout.widget.ConstraintLayout>

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:id="@+id/line4"
                            android:layout_marginHorizontal="@dimen/heightsize_16dp"
                            app:layout_constraintTop_toBottomOf="@+id/line3"
                            android:layout_marginTop="10sp"
                            app:layout_constraintStart_toStartOf="parent"
                            android:layout_height="wrap_content">


                            <TextView
                                android:id="@+id/lbl_remaining"
                                style="@style/labelStyle"
                                android:minWidth="130sp"
                                android:layout_width="wrap_content"
                                app:layout_constraintTop_toTopOf="parent"
                                android:text="@string/label_rem_limit"
                                app:layout_constraintStart_toStartOf="parent"
                                />

                            <TextView
                                android:id="@+id/remlimit"
                                style="@style/viewtextStyle"
                                android:minWidth="100dp"
                                android:layout_width="0dp"
                                app:layout_constraintTop_toTopOf="parent"
                                android:text=""
                                android:gravity="end"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toEndOf="@+id/lbl_remaining"
                                />

                            <View
                                android:layout_width="wrap_content"
                                android:layout_marginTop="10sp"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toBottomOf="@+id/remlimit"
                                android:background="@color/color_C7BFBF"
                                android:layout_height="0.5dp">

                            </View>

                        </androidx.constraintlayout.widget.ConstraintLayout>

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </com.google.android.material.card.MaterialCardView>


                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnsendotp"
                    style="@style/ThemeAppButton"
                    android:backgroundTint="@color/blue_app"
                    android:layout_marginTop="16sp"
                    android:visibility="gone"
                    android:layout_marginBottom="@dimen/heightsize_16dp"
                    app:layout_constraintTop_toBottomOf="@+id/materialcard"

                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:text="@string/btn_send_otp"
                    />


                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/lltransactionLayout"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:visibility="visible"
                    android:layout_marginTop="@dimen/heightsize_12dp"
                    android:paddingVertical="@dimen/heightsize_16dp"
                    android:orientation="vertical"
                    android:layout_marginBottom="@dimen/heightsize_16dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/btnsendotp"
                    android:focusableInTouchMode="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/transactiontitle"
                        style="@style/labelStyle"
                        android:layout_width="wrap_content"
                        app:layout_constraintTop_toTopOf="parent"
                        android:text="@string/lbl_bank_list"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:id="@+id/materialCard"
                        app:cardElevation="@dimen/heightsize_6dp"
                        app:layout_constraintTop_toBottomOf="@+id/transactiontitle"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:layout_marginTop="@dimen/heightsize_10dp"
                        android:layout_marginHorizontal="@dimen/_16sdp"
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="@dimen/_10sdp"
                        android:layout_height="wrap_content">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/fetchbillrecycler"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="@dimen/heightsize_16dp"
                        android:overScrollMode="never"
                        android:clipToPadding="false"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/transactiontitle"
                        tools:listitem="@layout/dmt_banklist_layout" />


                    </com.google.android.material.card.MaterialCardView>

                    <View
                        android:layout_width="wrap_content"
                        android:layout_marginTop="15sp"
                        android:id="@+id/view1"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/material"
                        android:layout_height="0.5dp">

                    </View>

                </androidx.constraintlayout.widget.ConstraintLayout>












            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.core.widget.NestedScrollView>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_cart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:layout_marginStart="@dimen/_2sdp"
            android:layout_marginTop="@dimen/_2sdp"
            android:layout_marginEnd="@dimen/heightsize_24dp"
            android:layout_marginBottom="@dimen/heightsize_27dp"
            android:elevation="@dimen/heightsize_7dp"
            android:scaleType="center"
            android:stateListAnimator="@null"
            app:backgroundTint="@color/color_F72F20"
            app:fabCustomSize="60dp"
            app:tint="@color/white"
            android:background="@drawable/circle_gradient_blue"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"

            app:maxImageSize="32dp"
            app:srcCompat="@drawable/add_account" />




    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>


