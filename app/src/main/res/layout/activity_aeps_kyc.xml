<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/color_F5EBEB">

        <include
            android:id="@+id/includeLayout"
            layout="@layout/toolbar_metarial_design">

        </include>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/svLogin"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:fillViewport="true"
            android:scrollbars="none"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/includeLayout">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/llRootLayout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingBottom="@dimen/_20sdp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:focusableInTouchMode="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="230dp"
                    android:id="@+id/image"
                    android:layout_height="@dimen/heightsize_80dp"
                    android:layout_gravity="center"
                    android:fontFamily="@font/dmsans_bold"
                    android:src="@drawable/logo"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"

                    android:paddingStart="16sp" />






                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:id="@+id/materialcard"
                    app:cardElevation="@dimen/heightsize_6dp"
                    app:layout_constraintTop_toBottomOf="@+id/image"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginTop="@dimen/heightsize_16dp"
                    android:layout_marginHorizontal="@dimen/_16sdp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="@dimen/_10sdp"
                    android:layout_height="wrap_content">


                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:paddingTop="@dimen/_16sdp"
                        android:paddingBottom="@dimen/heightsize_32dp"
                        android:layout_height="match_parent">


                        <TextView
                            android:id="@+id/tvDetail"
                            style="@style/TitleStyle"
                            app:layout_constraintTop_toTopOf="parent"
                            android:text="@string/text_kyc"
                            android:layout_marginHorizontal="@dimen/_16sdp"
                            android:gravity="center"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent" />


                        <View
                            android:id="@+id/viewLineOne"
                            android:layout_width="@dimen/heightsize_150dp"
                            android:layout_height="0.3dp"
                            app:layout_constraintTop_toBottomOf="@+id/tvDetail"
                            app:layout_constraintStart_toStartOf="parent"
                            android:layout_marginHorizontal="@dimen/heightsize_32dp"
                            app:layout_constraintEnd_toEndOf="parent"
                            android:layout_marginTop="@dimen/heightsize_10dp"
                            android:layout_marginBottom="@dimen/heightsize_16dp"
                            android:background="@color/blue_app"
                            android:visibility="visible"/>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilname"
                            style="@style/TextInputLayoutStyle"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginHorizontal="@dimen/heightsize_16dp"
                            android:layout_marginTop="@dimen/heightsize_15dp"
                            android:hint="@string/lbl_firstname"
                            app:layout_constraintTop_toBottomOf="@+id/viewLineOne"
                            app:placeholderText="@string/lbl_firstname">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etname"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/heightsize_50dp"
                                android:fontFamily="@font/dmsans_regular"
                                android:imeOptions="actionNext"
                                android:textCursorDrawable="@drawable/cursor"
                                android:inputType="textCapSentences"
                                />
                        </com.google.android.material.textfield.TextInputLayout>


                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tillastname"
                            style="@style/TextInputLayoutStyle"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginHorizontal="@dimen/heightsize_16dp"
                            android:layout_marginTop="@dimen/heightsize_10dp"
                            android:hint="@string/lbl_lastname"
                            app:layout_constraintTop_toBottomOf="@+id/tilname"
                            app:placeholderText="@string/lbl_lastname">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etlastname"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/heightsize_50dp"
                                android:fontFamily="@font/dmsans_regular"
                                android:imeOptions="actionNext"
                                android:textCursorDrawable="@drawable/cursor"
                                android:inputType="textCapSentences"
                                />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tildob"
                            style="@style/TextInputLayoutStyle"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginHorizontal="@dimen/heightsize_16dp"
                            android:layout_marginTop="@dimen/heightsize_10dp"
                            android:hint="@string/lbl_dob"
                            android:visibility="gone"
                            app:layout_constraintTop_toBottomOf="@+id/tillastname"
                            app:placeholderText="@string/placeholder_text_dob">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etdob"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/heightsize_50dp"
                                android:fontFamily="@font/dmsans_regular"
                                android:imeOptions="actionNext"
                                android:baselineAligned="false"
                                android:cursorVisible="false"
                                android:focusable="false"
                                android:textCursorDrawable="@drawable/cursor"
                                android:inputType="textEmailAddress"
                                />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilmobilenumber"
                            style="@style/TextInputLayoutStyle"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginHorizontal="@dimen/heightsize_16dp"
                            android:layout_marginTop="@dimen/heightsize_10dp"
                            android:hint="@string/lbl_user_name"
                            app:layout_constraintTop_toBottomOf="@+id/tildob"
                            app:placeholderText="@string/placeholder_text_mobile_no">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etmobilenumber"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/heightsize_50dp"
                                android:fontFamily="@font/dmsans_regular"
                                android:imeOptions="actionNext"
                                android:textCursorDrawable="@drawable/cursor"
                                android:inputType="number"
                                />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilemail"
                            style="@style/TextInputLayoutStyle"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginHorizontal="@dimen/heightsize_16dp"
                            android:layout_marginTop="@dimen/heightsize_10dp"
                            android:hint="@string/lbl_email"
                            app:layout_constraintTop_toBottomOf="@+id/tilmobilenumber"
                            app:placeholderText="@string/placeholder_text_email">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etemail"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/heightsize_50dp"
                                android:fontFamily="@font/dmsans_regular"
                                android:imeOptions="actionNext"
                                android:textCursorDrawable="@drawable/cursor"
                                android:inputType="textEmailAddress"
                                />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilshop"
                            style="@style/TextInputLayoutStyle"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginHorizontal="@dimen/heightsize_16dp"
                            android:layout_marginTop="@dimen/heightsize_10dp"
                            android:hint="@string/lbl_shop"
                            app:layout_constraintTop_toBottomOf="@+id/tiladdress"
                            app:placeholderText="@string/placeholder_shopname">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etshop"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/heightsize_50dp"
                                android:fontFamily="@font/dmsans_regular"
                                android:imeOptions="actionNext"
                                android:textCursorDrawable="@drawable/cursor"
                                android:inputType="textCapSentences"
                                />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilshopaddress"
                            style="@style/TextInputLayoutStyle"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginHorizontal="@dimen/heightsize_16dp"
                            android:layout_marginTop="@dimen/heightsize_10dp"
                            android:hint="@string/lbl_shopaddress"
                            app:layout_constraintTop_toBottomOf="@+id/tilshop"
                            app:placeholderText="@string/placeholder_shopaddress">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etshopaddress"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/heightsize_100dp"
                                android:fontFamily="@font/dmsans_regular"
                                android:imeOptions="actionNext"
                                android:gravity="top"
                                android:textCursorDrawable="@drawable/cursor"
                                android:inputType="textCapSentences"
                                />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tiladdress"
                            style="@style/TextInputLayoutStyle"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginHorizontal="@dimen/heightsize_16dp"
                            android:layout_marginTop="@dimen/heightsize_10dp"
                            android:hint="@string/placeholder_address"
                            app:layout_constraintTop_toBottomOf="@+id/tilemail"
                            app:placeholderText="@string/placeholder_address">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etaddress"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/heightsize_100dp"
                                android:fontFamily="@font/dmsans_regular"
                                android:imeOptions="actionNext"
                                android:gravity="top"
                                android:textCursorDrawable="@drawable/cursor"
                                android:inputType="textCapSentences"
                                />
                        </com.google.android.material.textfield.TextInputLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:orientation="horizontal"
                            android:visibility="gone"
                            android:id="@+id/shopImagelayout"
                            android:paddingVertical="@dimen/_8sdp"
                            android:layout_height="@dimen/_110sdp"
                            android:layout_marginHorizontal="@dimen/heightsize_8dp"
                            app:layout_constraintTop_toBottomOf="@+id/tilshopaddress">


                            <ImageView
                                android:layout_width="match_parent"
                                android:src="@drawable/img_shop_upload"
                                android:layout_weight="1"
                                android:id="@+id/uploadshop"
                                android:layout_margin="@dimen/heightsize_5dp"
                                android:layout_height="wrap_content">
                            </ImageView>


                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/cvUserDetail"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_margin="@dimen/heightsize_5dp"
                                android:layout_weight="1"
                                app:cardBackgroundColor="@color/white"
                                app:cardCornerRadius="@dimen/heightsize_8dp"
                                app:cardElevation="4dp"
                                app:layout_constraintTop_toTopOf="parent">

                                <androidx.constraintlayout.widget.ConstraintLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content">


                                    <ImageView
                                        android:layout_width="match_parent"
                                        android:src="@drawable/shopimages"
                                        android:id="@+id/shopImage"
                                        app:layout_constraintTop_toTopOf="parent"
                                        android:layout_height="wrap_content">

                                    </ImageView>


                                </androidx.constraintlayout.widget.ConstraintLayout>



                            </com.google.android.material.card.MaterialCardView>

                            <ImageView
                                android:layout_width="@dimen/heightsize_24dp"
                                android:src="@drawable/cross"
                                android:id="@+id/cross1"
                                android:visibility="gone"
                                app:layout_constraintTop_toTopOf="@+id/panimg"
                                app:layout_constraintEnd_toEndOf="@+id/panimg"
                                app:layout_constraintBottom_toTopOf="@+id/panimg"
                                android:layout_height="@dimen/heightsize_24dp">

                            </ImageView>

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:orientation="horizontal"
                            android:id="@+id/layout"
                            android:layout_height="wrap_content"
                            app:layout_constraintTop_toBottomOf="@+id/shopImagelayout">


                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/tilpincode"
                                style="@style/TextInputLayoutStyle"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_marginHorizontal="@dimen/heightsize_16dp"
                                android:layout_weight="1"
                                android:hint="@string/lbl_pincode"
                                app:layout_constraintTop_toBottomOf="@+id/tilshop"
                                app:placeholderText="@string/placeholder_pincode">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etpincode"
                                    android:layout_width="match_parent"
                                    android:layout_height="@dimen/heightsize_50dp"
                                    android:fontFamily="@font/dmsans_regular"
                                    android:imeOptions="actionNext"
                                    android:textCursorDrawable="@drawable/cursor"
                                    android:inputType="number"
                                    />
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/tilcity"
                                style="@style/TextInputLayoutStyle"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_marginHorizontal="@dimen/heightsize_16dp"
                                android:layout_weight="1"
                                android:hint="@string/lbl_city"
                                app:layout_constraintTop_toBottomOf="@+id/tilshop"
                                app:placeholderText="@string/placeholder_city">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etcity"
                                    android:layout_width="match_parent"
                                    android:layout_height="@dimen/heightsize_50dp"
                                    android:fontFamily="@font/dmsans_regular"
                                    android:imeOptions="actionNext"
                                    android:textCursorDrawable="@drawable/cursor"
                                    android:inputType="textCapSentences"
                                    />
                            </com.google.android.material.textfield.TextInputLayout>

                        </LinearLayout>


                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilstate"
                            style="@style/dropdown"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginHorizontal="@dimen/heightsize_16dp"
                            android:layout_marginTop="@dimen/heightsize_10dp"
                            app:hintEnabled="false"
                            app:layout_constraintTop_toBottomOf="@+id/layout">

                            <AutoCompleteTextView
                                android:id="@+id/etstate"
                                android:layout_width="match_parent"
                                android:layout_height="50dp"
                                android:background="@drawable/drawable_edit_text_bg"
                                android:baselineAligned="false"
                                android:drawableRight="@drawable/drop"
                                android:hint="@string/lbl_State"
                                android:paddingHorizontal="@dimen/heightsize_11dp"
                                android:imeOptions="actionNext"
                                android:inputType="none"
                                android:textColor="@color/black"
                                android:textColorHint="@color/white_60"
                                android:textCursorDrawable="@drawable/cursor"/>
                        </com.google.android.material.textfield.TextInputLayout>


                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilpan"
                            style="@style/TextInputLayoutStyle"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginHorizontal="@dimen/heightsize_16dp"
                            android:layout_marginTop="@dimen/heightsize_10dp"
                            android:hint="@string/lbl_pan_number"
                            app:layout_constraintTop_toBottomOf="@+id/tilstate"
                            app:placeholderText="@string/placeholder_pannumber">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etpan"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/heightsize_50dp"
                                android:fontFamily="@font/dmsans_regular"
                                android:imeOptions="actionNext"
                                android:textCursorDrawable="@drawable/cursor"
                                android:inputType="textCapCharacters"
                                />
                        </com.google.android.material.textfield.TextInputLayout>


                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tiladhar"
                            style="@style/TextInputLayoutStyle"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginHorizontal="@dimen/heightsize_16dp"
                            android:layout_marginTop="@dimen/heightsize_10dp"
                            android:hint="@string/lbl_adhar"
                            app:layout_constraintTop_toBottomOf="@+id/tilpan"
                            app:placeholderText="@string/placeholder_adhar">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etadhar"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/heightsize_50dp"
                                android:fontFamily="@font/dmsans_regular"
                                android:imeOptions="actionNext"
                                android:textCursorDrawable="@drawable/cursor"
                                android:inputType="number"
                                />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilholdername"
                            style="@style/TextInputLayoutStyle"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginHorizontal="@dimen/heightsize_16dp"
                            android:layout_marginTop="@dimen/heightsize_10dp"
                            android:hint="@string/lbl_bank_holder_name"
                            app:layout_constraintTop_toBottomOf="@+id/tiladhar"
                            app:placeholderText="@string/lbl_bank_holder_name">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etholdername"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/heightsize_50dp"
                                android:fontFamily="@font/dmsans_regular"
                                android:imeOptions="actionNext"
                                android:textCursorDrawable="@drawable/cursor"
                                android:inputType="textCapSentences"
                                />
                        </com.google.android.material.textfield.TextInputLayout>


                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilBankName"
                            style="@style/TextInputLayoutStyle"
                            android:visibility="visible"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginHorizontal="@dimen/heightsize_16dp"
                            android:layout_marginTop="@dimen/heightsize_10dp"
                            app:hintEnabled="true"
                            android:hint="@string/please_enter1_bank"
                            app:layout_constraintTop_toBottomOf="@+id/tilholdername">

                           <!-- <AutoCompleteTextView
                                android:id="@+id/etbank"
                                android:layout_width="match_parent"
                                android:layout_height="50dp"
                                android:background="@drawable/drawable_edit_text_bg"
                                android:baselineAligned="false"
                                android:drawableRight="@drawable/drop"
                                android:hint="@string/please_enter_bank"
                                android:paddingHorizontal="@dimen/heightsize_11dp"
                                android:imeOptions="actionNext"
                                android:inputType="none"
                                android:textColor="@color/black"
                                android:textColorHint="@color/white_60"
                                android:textCursorDrawable="@drawable/cursor"/>-->

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etbank"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/heightsize_50dp"
                                android:fontFamily="@font/dmsans_regular"
                                android:imeOptions="actionNext"
                                android:textCursorDrawable="@drawable/cursor"
                                android:inputType="text"
                                />

                        </com.google.android.material.textfield.TextInputLayout>


                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilBankAccountName"
                            style="@style/TextInputLayoutStyle"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginHorizontal="@dimen/heightsize_16dp"
                            android:layout_marginTop="@dimen/heightsize_10dp"
                            android:hint="@string/txt_bank_account_number"
                            app:layout_constraintTop_toBottomOf="@+id/tilBankName"
                            app:placeholderText="@string/txt_bank_account_number">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etBankAccountName"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/heightsize_50dp"
                                android:fontFamily="@font/dmsans_regular"
                                android:imeOptions="actionNext"
                                android:textCursorDrawable="@drawable/cursor"
                                android:inputType="number"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilIfecCode"
                            style="@style/TextInputLayoutStyle"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginHorizontal="@dimen/heightsize_16dp"
                            android:layout_marginTop="@dimen/heightsize_10dp"
                            android:hint="@string/txt_bank_ifsc_code"
                            app:layout_constraintTop_toBottomOf="@+id/tilBankAccountName"
                            app:placeholderText="@string/txt_bank_ifsc_code">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etIfscCode"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/heightsize_50dp"
                                android:fontFamily="@font/dmsans_regular"
                                android:imeOptions="actionNext"
                                android:textCursorDrawable="@drawable/cursor"
                                android:inputType="textCapSentences"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tiloutlet"
                            style="@style/TextInputLayoutStyle"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:visibility="gone"
                            android:layout_marginHorizontal="@dimen/heightsize_16dp"
                            android:layout_marginTop="@dimen/heightsize_10dp"
                            android:hint="@string/txt_outlet"
                            app:layout_constraintTop_toBottomOf="@+id/tilIfecCode"
                            app:placeholderText="@string/txt_outlet_id">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etoutlet"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/heightsize_50dp"
                                android:fontFamily="@font/dmsans_regular"
                                android:imeOptions="actionNext"
                                android:textCursorDrawable="@drawable/cursor"
                                android:inputType="textCapSentences"/>
                        </com.google.android.material.textfield.TextInputLayout>


                    </androidx.constraintlayout.widget.ConstraintLayout>

                </com.google.android.material.card.MaterialCardView>


                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnsubmit"
                    style="@style/ThemeAppButton"
                    android:backgroundTint="@color/color_F72F20"
                    android:layout_marginTop="@dimen/heightsize_16dp"
                    app:layout_constraintTop_toBottomOf="@+id/materialcard"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:text="@string/btn_text_submit"
                    />



            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.core.widget.NestedScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>


