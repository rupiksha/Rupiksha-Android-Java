                                app:layout_constraintStart_toStartOf="parent"
                                />

                            <TextView
                                android:id="@+id/lbl_value2"
                                style="@style/cardtextStyle"
                                android:minWidth="100sp"
                                android:layout_width="0dp"
                                app:layout_constraintTop_toTopOf="parent"
                                android:text="Jenifer"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toEndOf="@+id/lbl_name2"
                                />

                            <View
                                android:layout_width="wrap_content"
                                android:layout_marginTop="7sp"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toBottomOf="@+id/lbl_value2"
                                android:background="@color/color_C7BFBF"
                                android:layout_height="0.5dp">

                            </View>

                        </androidx.constraintlayout.widget.ConstraintLayout>

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:id="@+id/line3"
                            android:layout_marginHorizontal="@dimen/heightsize_16dp"
                            app:layout_constraintTop_toBottomOf="@+id/line2"
                            android:layout_marginTop="10sp"
                            app:layout_constraintStart_toStartOf="parent"
                            android:layout_height="wrap_content">


                            <TextView
                                android:id="@+id/lbl_name3"
                                style="@style/cardlabelStyle"
                                android:minWidth="130sp"
                                android:layout_width="wrap_content"
                                app:layout_constraintTop_toTopOf="parent"
                                android:text="@string/lbl_tx_id"

                                app:layout_constraintStart_toStartOf="parent"
                                />

                            <TextView
                                android:id="@+id/lbl_value3"
                                style="@style/cardtextStyle"
                                android:minWidth="100sp"
                                android:layout_width="0dp"
                                app:layout_constraintTop_toTopOf="parent"
                                android:text="ECZN42458956"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toEndOf="@+id/lbl_name3"
                                />

                            <View
                                android:layout_width="wrap_content"
                                android:layout_marginTop="7sp"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toBottomOf="@+id/lbl_value3"
                                android:background="@color/color_C7BFBF"
                                android:layout_height="0.5dp">

                            </View>

                        </androidx.constraintlayout.widget.ConstraintLayout>

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:id="@+id/line4"
                            android:layout_marginHorizontal="@dimen/heightsize_16dp"
                            app:layout_constraintTop_toBottomOf="@+id/line3"
                            android:layout_marginTop="10sp"
                            app:layout_constraintStart_toStartOf="parent"
                            android:layout_height="wrap_content">


                            <TextView
                                android:id="@+id/lbl_name4"
                                style="@style/cardlabelStyle"
                                android:minWidth="130sp"
                                android:layout_width="wrap_content"
                                app:layout_constraintTop_toTopOf="parent"
                                android:text="@string/lbl_amount"

                                app:layout_constraintStart_toStartOf="parent"
                                />

                            <TextView
                                android:id="@+id/lbl_value4"
                                style="@style/cardtextStyle"
                                android:minWidth="100sp"
                                android:layout_width="0dp"
                                app:layout_constraintTop_toTopOf="parent"
                                android:text="₹ 1570"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toEndOf="@+id/lbl_name4"
                                />

                            <View
                                android:layout_width="wrap_content"
                                android:layout_marginTop="7sp"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toBottomOf="@+id/lbl_value4"
                                android:background="@color/color_C7BFBF"
                                android:layout_height="0.5dp">

                            </View>

                        </androidx.constraintlayout.widget.ConstraintLayout>

