                    style="@style/ThemeAppButton"
                    android:backgroundTint="@color/blue_app"
                    android:layout_marginTop="16sp"
                    android:layout_marginBottom="@dimen/heightsize_16dp"
                    android:visibility="gone"
                    app:layout_constraintTop_toBottomOf="@+id/materialcard"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:text="@string/btn_text_fetch_bill"
                    />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnpaynow1"
                    style="@style/ThemeAppButton"
                    android:backgroundTint="@color/color_F72F20"
                    android:layout_marginTop="16sp"
                    android:visibility="gone"
                    android:layout_marginBottom="@dimen/heightsize_16dp"
                    app:layout_constraintTop_toBottomOf="@+id/btnfetchbill"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:text="@string/btn_paynow"
                    />

                <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/llfetchbillLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/heightsize_12dp"
                android:orientation="vertical"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/btnfetchbill"
                android:focusableInTouchMode="true"
                android:focusable="true">

                <TextView
