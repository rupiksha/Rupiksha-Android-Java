<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">
<androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_F5EBEB"
    tools:context=".activities.PanVerificationActivity">

    <include
        android:id="@+id/includeLayout"
        layout="@layout/toolbar_metarial_design">

    </include>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/svLogin"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/includeLayout">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/llRootLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingBottom="@dimen/_20sdp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:focusableInTouchMode="true"
            android:focusable="true">

            <ImageView
                android:layout_width="230dp"
                android:id="@+id/image"
                android:layout_height="@dimen/heightsize_100dp"
                android:layout_gravity="center"
                android:fontFamily="@font/dmsans_bold"
                android:src="@drawable/logo"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:paddingStart="16sp" />



            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:id="@+id/materialcard"
                app:cardElevation="@dimen/heightsize_6dp"
                app:layout_constraintTop_toBottomOf="@+id/image"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="@dimen/heightsize_16dp"
                android:layout_marginHorizontal="@dimen/_16sdp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="@dimen/_10sdp"
                android:layout_height="wrap_content">


                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:paddingTop="@dimen/_16sdp"
                    android:paddingBottom="@dimen/heightsize_32dp"
                    android:layout_height="match_parent">


                    <TextView
                        android:id="@+id/tvtitle"
                        style="@style/TitleStyle"
                        app:layout_constraintTop_toTopOf="parent"
                        android:layout_marginHorizontal="@dimen/_16sdp"
                        android:gravity="center"
                        android:text="@string/label_pan_verfication"
                        android:layout_marginTop="@dimen/textsize_10sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />


                    <View
                        android:id="@+id/viewLineOne"
                        android:layout_width="@dimen/heightsize_150dp"
                        android:layout_height="0.3dp"
                        app:layout_constraintTop_toBottomOf="@+id/tvtitle"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginHorizontal="@dimen/heightsize_32dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:layout_marginTop="@dimen/heightsize_10dp"
                        android:layout_marginBottom="@dimen/heightsize_16dp"
                        android:background="@color/blue_app"
                        android:visibility="visible"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilaccount"
                        style="@style/TextInputLayoutStyle"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginHorizontal="@dimen/heightsize_16dp"
                        android:layout_marginTop="@dimen/heightsize_20dp"
                        android:hint="@string/lbl_pan_number"
                        app:layout_constraintTop_toBottomOf="@+id/viewLineOne"
                        app:placeholderText="@string/placeholder_pannumber">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etaccountnumber"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/heightsize_60dp"
                            android:fontFamily="@font/dmsans_regular"
                            android:imeOptions="actionNext"
                            android:textCursorDrawable="@drawable/cursor"
                            android:inputType="text"
                            android:textAllCaps="true"
                            />
                    </com.google.android.material.textfield.TextInputLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>


            <com.google.android.material.button.MaterialButton
                android:id="@+id/submit"
                style="@style/ThemeAppButton"
                android:backgroundTint="@color/color_F72F20"
                android:layout_marginTop="16sp"
                android:layout_marginBottom="@dimen/heightsize_16dp"
                app:layout_constraintTop_toBottomOf="@+id/materialcard"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:text="@string/btn_verify_pan"
                />
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:id="@+id/materialcard1"
                app:cardElevation="@dimen/heightsize_6dp"
                app:layout_constraintTop_toBottomOf="@+id/submit"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="@dimen/heightsize_16dp"
                android:visibility="gone"
                android:layout_marginHorizontal="@dimen/_16sdp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="@dimen/_10sdp"
                android:layout_height="wrap_content">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:paddingTop="@dimen/heightsize_12dp"
                android:layout_height="wrap_content">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:id="@+id/line1"
                    android:layout_marginHorizontal="@dimen/heightsize_16dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    android:layout_height="wrap_content">


                    <TextView
                        android:id="@+id/lbl_name"
                        style="@style/cardlabelStyle"
                        android:minWidth="130sp"
                        android:layout_width="wrap_content"
                        app:layout_constraintTop_toTopOf="parent"
                        android:text="@string/lbl_name"
                        app:layout_constraintStart_toStartOf="parent" />

                    <TextView
                        android:id="@+id/c_name"
                        style="@style/cardtextStyle"
                        android:minWidth="100sp"
                        android:layout_width="0dp"
                        android:gravity="end"
                        app:layout_constraintTop_toTopOf="parent"
                        android:text=""
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/lbl_name"
                        />

                    <View
                        android:layout_width="wrap_content"
                        android:layout_marginTop="7sp"
                        android:visibility="invisible"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/c_name"
                        android:background="@color/color_C7BFBF"
                        android:layout_height="0.5dp">

                    </View>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:id="@+id/line2"
                    android:layout_marginHorizontal="@dimen/heightsize_16dp"
                    app:layout_constraintTop_toBottomOf="@+id/line1"
                    app:layout_constraintStart_toStartOf="parent"
                    android:layout_height="wrap_content">


                    <TextView
                        android:id="@+id/lbl_status"
                        style="@style/cardlabelStyle"
                        android:minWidth="130sp"
                        android:layout_width="wrap_content"
                        app:layout_constraintTop_toTopOf="parent"
                        android:text="@string/lbl_status"

                        app:layout_constraintStart_toStartOf="parent"
                        />

                    <TextView
                        android:id="@+id/status"
                        style="@style/cardtextStyle"
                        android:minWidth="100sp"
                        android:layout_width="0dp"
                        android:gravity="end"
                        app:layout_constraintTop_toTopOf="parent"
                        android:text=""
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/lbl_status"
                        />

                    <View
                        android:layout_width="wrap_content"
                        android:layout_marginTop="7sp"
                        android:visibility="invisible"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/status"
                        android:background="@color/color_C7BFBF"
                        android:layout_height="0.5dp">

                    </View>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:id="@+id/line3"
                    android:layout_marginHorizontal="@dimen/heightsize_16dp"
                    app:layout_constraintTop_toBottomOf="@+id/line2"
                    app:layout_constraintStart_toStartOf="parent"
                    android:layout_height="wrap_content">


                    <TextView
                        android:id="@+id/lbl_gender"
                        style="@style/cardlabelStyle"
                        android:minWidth="130sp"
                        android:layout_width="wrap_content"
                        app:layout_constraintTop_toTopOf="parent"
                        android:text="@string/lbl_gender"
                        app:layout_constraintStart_toStartOf="parent"
                        />

                    <TextView
                        android:id="@+id/gender"
                        style="@style/cardtextStyle"
                        android:minWidth="100sp"
                        android:layout_width="0dp"
                        android:gravity="end"
                        app:layout_constraintTop_toTopOf="parent"
                        android:text=""
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/lbl_gender"
                        />

                    <View
                        android:layout_width="wrap_content"
                        android:layout_marginTop="7sp"
                        android:visibility="invisible"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/gender"
                        android:background="@color/color_C7BFBF"
                        android:layout_height="0.5dp">

                    </View>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:id="@+id/line4"
                    android:layout_marginHorizontal="@dimen/heightsize_16dp"
                    app:layout_constraintTop_toBottomOf="@+id/line3"
                    app:layout_constraintStart_toStartOf="parent"
                    android:layout_height="wrap_content">


                    <TextView
                        android:id="@+id/lbl_date"
                        style="@style/cardlabelStyle"
                        android:minWidth="130sp"
                        android:layout_width="wrap_content"
                        app:layout_constraintTop_toTopOf="parent"
                        android:text="@string/lbl_date"

                        app:layout_constraintStart_toStartOf="parent"
                        />

                    <TextView
                        android:id="@+id/date"
                        style="@style/cardtextStyle"
                        android:minWidth="100sp"
                        android:layout_width="0dp"
                        app:layout_constraintTop_toTopOf="parent"
                        android:text=""
                        android:gravity="end"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/lbl_date"
                        />

                    <View
                        android:layout_width="wrap_content"
                        android:layout_marginTop="7sp"
                        android:visibility="invisible"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/date"
                        android:background="@color/color_C7BFBF"
                        android:layout_height="0.5dp">
                    </View>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:id="@+id/line5"
                    android:layout_marginHorizontal="@dimen/heightsize_16dp"
                    app:layout_constraintTop_toBottomOf="@+id/line4"
                    app:layout_constraintStart_toStartOf="parent"
                    android:layout_height="wrap_content">


                    <TextView
                        android:id="@+id/lbl_constitution"
                        style="@style/cardlabelStyle"
                        android:minWidth="130sp"
                        android:layout_width="wrap_content"
                        app:layout_constraintTop_toTopOf="parent"
                        android:text="@string/lbl_constitution"

                        app:layout_constraintStart_toStartOf="parent"
                        />

                    <TextView
                        android:id="@+id/constitution"
                        style="@style/cardtextStyle"
                        android:minWidth="100sp"
                        android:layout_width="0dp"
                        app:layout_constraintTop_toTopOf="parent"
                        android:text=""
                        android:gravity="end"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/lbl_constitution"
                        />

                    <View
                        android:layout_width="wrap_content"
                        android:layout_marginTop="7sp"
                        android:visibility="invisible"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/constitution"
                        android:background="@color/color_C7BFBF"
                        android:layout_height="0.5dp">
                    </View>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <View
                    android:layout_width="wrap_content"
                    android:layout_marginTop="7sp"
                    android:visibility="invisible"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/line5"
                    android:background="@color/color_C7BFBF"
                    android:layout_height="0.5dp">

                </View>

            </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>





        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>


</androidx.constraintlayout.widget.ConstraintLayout>
</layout>