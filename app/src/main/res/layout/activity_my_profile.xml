<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/color_F5EBEB">

        <include
            android:id="@+id/includeLayout"
            layout="@layout/toolbar_metarial_design">

        </include>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/svLogin"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:fillViewport="true"
            android:scrollbars="none"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/includeLayout">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/llRootLayout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingBottom="20dp"
                app:layout_constraintTop_toTopOf="parent"
                android:focusableInTouchMode="true"
                android:focusable="true">


                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cvUserDetail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/heightsize_16dp"
                    android:layout_marginTop="56dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="@dimen/heightsize_16dp"
                    app:cardElevation="4dp"
                    app:layout_constraintTop_toTopOf="parent">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:paddingTop="@dimen/_16sdp"
                        android:paddingBottom="@dimen/heightsize_32dp"
                        android:layout_height="wrap_content">



                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:id="@+id/line1"
                            android:layout_marginHorizontal="@dimen/heightsize_16dp"
                            android:layout_marginTop="@dimen/heightsize_40dp"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            android:layout_height="wrap_content">


                            <TextView
                                android:id="@+id/lbl_name"
                                style="@style/labelStyle"
                                android:minWidth="130sp"
                                android:layout_width="wrap_content"
                                app:layout_constraintTop_toTopOf="parent"
                                android:text="@string/label_name"

                                app:layout_constraintStart_toStartOf="parent"
                                />

                            <TextView
                                android:id="@+id/name"
                                style="@style/viewtextStyle"
                                android:minWidth="100sp"
                                android:layout_width="0dp"
                                app:layout_constraintTop_toTopOf="parent"
                                android:text=""
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toEndOf="@+id/lbl_name"
                                />

                            <View
                                android:layout_width="wrap_content"
                                android:layout_marginTop="10sp"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toBottomOf="@+id/name"
                                android:background="@color/color_C7BFBF"
                                android:layout_height="0.5dp">

                            </View>

                        </androidx.constraintlayout.widget.ConstraintLayout>

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:id="@+id/line2"
                            android:layout_marginHorizontal="@dimen/heightsize_16dp"
                            app:layout_constraintTop_toBottomOf="@+id/line1"
                            android:layout_marginTop="10sp"
                            app:layout_constraintStart_toStartOf="parent"
                            android:layout_height="wrap_content">


                            <TextView
                                android:id="@+id/lbl_mobile"
                                style="@style/labelStyle"
                                android:minWidth="130sp"
                                android:layout_width="wrap_content"
                                app:layout_constraintTop_toTopOf="parent"
                                android:text="@string/label_mobile_number"

                                app:layout_constraintStart_toStartOf="parent"
                                />

                            <TextView
                                android:id="@+id/mobile"
                                style="@style/viewtextStyle"
                                android:minWidth="100sp"
                                android:layout_width="0dp"
                                app:layout_constraintTop_toTopOf="parent"
                                android:text=""
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toEndOf="@+id/lbl_mobile"
                                />

                            <View
                                android:layout_width="wrap_content"
                                android:layout_marginTop="10sp"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toBottomOf="@+id/mobile"
                                android:background="@color/color_C7BFBF"
                                android:layout_height="0.5dp">

                            </View>

                        </androidx.constraintlayout.widget.ConstraintLayout>

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:id="@+id/line3"
                            android:layout_marginHorizontal="@dimen/heightsize_16dp"
                            app:layout_constraintTop_toBottomOf="@+id/line2"
                            android:layout_marginTop="10sp"
                            app:layout_constraintStart_toStartOf="parent"
                            android:layout_height="wrap_content">


                            <TextView
                                android:id="@+id/lbl_email"
                                style="@style/labelStyle"
                                android:minWidth="130sp"
                                android:layout_width="wrap_content"
                                app:layout_constraintTop_toTopOf="parent"
                                android:text="@string/label_email"

                                app:layout_constraintStart_toStartOf="parent"
                                />

                            <TextView
                                android:id="@+id/email"
                                style="@style/viewtextStyle"
                                android:minWidth="100sp"
                                android:layout_width="0dp"
                                app:layout_constraintTop_toTopOf="parent"
                                android:text=""
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toEndOf="@+id/lbl_email"
                                />

                            <View
                                android:layout_width="wrap_content"
                                android:layout_marginTop="10sp"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toBottomOf="@+id/email"
                                android:background="@color/color_C7BFBF"
                                android:layout_height="0.5dp">

                            </View>

                        </androidx.constraintlayout.widget.ConstraintLayout>

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:id="@+id/line4"
                            android:layout_marginHorizontal="@dimen/heightsize_16dp"
                            app:layout_constraintTop_toBottomOf="@+id/line3"
                            android:layout_marginTop="10sp"
                            app:layout_constraintStart_toStartOf="parent"
                            android:layout_height="wrap_content">


                            <TextView
                                android:id="@+id/lbl_aadhaar"
                                style="@style/labelStyle"
                                android:minWidth="130sp"
                                android:layout_width="wrap_content"
                                app:layout_constraintTop_toTopOf="parent"
                                android:text="@string/label_aadhaar"

                                app:layout_constraintStart_toStartOf="parent"
                                />

                            <TextView
                                android:id="@+id/aadhaar"
                                style="@style/viewtextStyle"
                                android:minWidth="100sp"
                                android:layout_width="0dp"
                                app:layout_constraintTop_toTopOf="parent"
                                android:text=""
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toEndOf="@+id/lbl_aadhaar"
                                />

                            <View
                                android:layout_width="wrap_content"
                                android:layout_marginTop="10sp"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toBottomOf="@+id/aadhaar"
                                android:background="@color/color_C7BFBF"
                                android:layout_height="0.5dp">

                            </View>

                        </androidx.constraintlayout.widget.ConstraintLayout>

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:id="@+id/line5"
                            android:layout_marginHorizontal="@dimen/heightsize_16dp"
                            app:layout_constraintTop_toBottomOf="@+id/line4"
                            android:layout_marginTop="10sp"
                            app:layout_constraintStart_toStartOf="parent"
                            android:layout_height="wrap_content">


                            <TextView
                                android:id="@+id/lbl_pan"
                                style="@style/labelStyle"
                                android:minWidth="130sp"
                                android:layout_width="wrap_content"
                                app:layout_constraintTop_toTopOf="parent"
                                android:text="@string/label_pan"

                                app:layout_constraintStart_toStartOf="parent"
                                />

                            <TextView
                                android:id="@+id/pan"
                                style="@style/viewtextStyle"
                                android:minWidth="100sp"
                                android:layout_width="0dp"
                                app:layout_constraintTop_toTopOf="parent"
                                android:text=""
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toEndOf="@+id/lbl_pan"
                                />

                            <View
                                android:layout_width="wrap_content"
                                android:layout_marginTop="10sp"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toBottomOf="@+id/pan"
                                android:background="@color/color_C7BFBF"
                                android:layout_height="0.5dp">

                            </View>

                        </androidx.constraintlayout.widget.ConstraintLayout>

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:id="@+id/line6"
                            android:layout_marginHorizontal="@dimen/heightsize_16dp"
                            app:layout_constraintTop_toBottomOf="@+id/line5"
                            android:layout_marginTop="10sp"
                            app:layout_constraintStart_toStartOf="parent"
                            android:layout_height="wrap_content">


                            <TextView
                                android:id="@+id/lbl_address"
                                style="@style/labelStyle"
                                android:minWidth="130sp"
                                android:layout_width="wrap_content"
                                app:layout_constraintTop_toTopOf="parent"
                                android:text="@string/label_address"

                                app:layout_constraintStart_toStartOf="parent"
                                />

                            <TextView
                                android:id="@+id/address"
                                style="@style/viewtextStyle"
                                android:minWidth="100sp"
                                android:layout_width="0dp"
                                app:layout_constraintTop_toTopOf="parent"
                                android:text=""
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toEndOf="@+id/lbl_address"
                                />

                            <View
                                android:layout_width="wrap_content"
                                android:layout_marginTop="10sp"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toBottomOf="@+id/address"
                                android:background="@color/color_C7BFBF"
                                android:layout_height="0.5dp">

                            </View>

                        </androidx.constraintlayout.widget.ConstraintLayout>





                    </androidx.constraintlayout.widget.ConstraintLayout>

                </com.google.android.material.card.MaterialCardView>

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/civUserImage"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/default_user_image"
                    android:elevation="6dp"
                    android:src="@drawable/profile"
                    app:layout_constraintBottom_toTopOf="@+id/cvUserDetail"
                    app:layout_constraintEnd_toEndOf="@+id/cvUserDetail"
                    app:layout_constraintStart_toStartOf="@+id/cvUserDetail"
                    app:layout_constraintTop_toTopOf="@+id/cvUserDetail" />





                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnedit1"
                    style="@style/ThemeAppButton"
                    android:backgroundTint="@color/blue_app"
                    android:layout_marginTop="16sp"
                    android:layout_marginStart="@dimen/_80sdp"
                    android:layout_marginEnd="@dimen/_80sdp"
                     app:icon="@drawable/edit_profile"
                     app:iconGravity="textStart"
                    android:textAlignment="center"

                    app:layout_constraintTop_toBottomOf="@+id/cvUserDetail"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:text="@string/btn_text_edit"
                    />



            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.core.widget.NestedScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>


