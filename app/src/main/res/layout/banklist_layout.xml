<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">





        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:paddingTop="@dimen/heightsize_12dp"
            android:layout_height="wrap_content">





            <LinearLayout
                android:layout_width="match_parent"
                android:id="@+id/line2"
                android:orientation="horizontal"
                android:weightSum="5"
                android:layout_marginHorizontal="@dimen/heightsize_16dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_height="wrap_content">


                <TextView
                    android:id="@+id/accountnumber"
                    style="@style/cardlabelStyle"
                    android:layout_width="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text="@string/lbl_account_number"
                    android:layout_weight="2"
                    app:layout_constraintStart_toStartOf="parent"
                    />

                <TextView
                    android:id="@+id/name"
                    style="@style/cardlabelStyle"
                    android:layout_width="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text="@string/lbl_name"
                    android:layout_weight="1"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/lbl_name"
                    />
                <TextView
                    android:id="@+id/status"
                    style="@style/cardlabelStyle"
                    android:layout_weight="1"
                    android:layout_width="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text="@string/lbl_stat"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/lbl_name"
                    />

                <TextView
                    android:id="@+id/action"
                    style="@style/cardlabelStyle"
                    android:layout_weight="1"
                    android:layout_width="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text="@string/lbl_action"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/lbl_name"
                    />





            </LinearLayout>

            <View
                android:layout_width="wrap_content"
                android:layout_marginTop="5sp"
                android:id="@+id/view1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/line2"
                android:background="@color/color_C7BFBF"
                android:layout_height="0.5dp">

            </View>

            <LinearLayout
                android:layout_width="match_parent"
                android:id="@+id/line4"
                android:orientation="horizontal"
                android:weightSum="5"
                android:layout_marginTop="@dimen/heightsize_5dp"
                android:layout_marginHorizontal="@dimen/heightsize_16dp"
                app:layout_constraintTop_toBottomOf="@+id/view1"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_height="wrap_content">


                <TextView
                    android:id="@+id/valueaccountnumber"
                    style="@style/cardtextStyle"
                    android:gravity="center_vertical"
                    android:layout_height="match_parent"
                    android:layout_width="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text=""
                    android:layout_weight="2"
                    app:layout_constraintStart_toStartOf="parent"
                    />

                <TextView
                    android:id="@+id/valuename"
                    style="@style/cardtextStyle"
                    android:gravity="center_vertical"
                    android:layout_height="match_parent"
                    android:layout_width="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text=""
                    android:layout_weight="1"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/lbl_name"
                    />
                <TextView
                    android:id="@+id/valuestatus"
                    style="@style/cardtextStyle"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:layout_height="match_parent"
                    android:layout_width="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text=""
                    android:fontFamily="@font/dmsans_bold"
                    android:textColor="@color/color_259A2A"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/lbl_name"
                    />

                <ImageView
                    android:id="@+id/valueaction"
                    style="@style/cardtextStyle"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:layout_width="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    android:src="@drawable/delete"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/lbl_name"

                    />





            </LinearLayout>


        </androidx.constraintlayout.widget.ConstraintLayout>




</layout>