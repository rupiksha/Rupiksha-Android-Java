<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/svLogin"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:fillViewport="true"
            android:scrollbars="none"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/llRootLayout"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:focusableInTouchMode="true"
                android:focusable="true">

                <RadioGroup
                    android:id="@+id/toggle"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/heightsize_56dp"
                    android:layout_marginStart="16sp"
                    android:layout_marginTop="@dimen/heightsize_7dp"
                    android:layout_marginEnd="16sp"
                    android:background="@color/color_C5C5C5"
                    android:checkedButton="@+id/offer"
                    android:minHeight="@dimen/heightsize_56dp"
                    android:orientation="horizontal"
                    android:padding="@dimen/heightsize_4dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">
                </RadioGroup>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/llwhistory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="visible"
                    android:focusableInTouchMode="true"
                    android:focusable="true"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/toggle">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:id="@+id/datelayout"
                        android:layout_marginTop="@dimen/heightsize_16dp"
                        android:layout_gravity="center_vertical"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <LinearLayout
                            android:id="@+id/ll_date_from"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="15dp"
                            android:layout_weight="1"
                            android:background="@drawable/shimmer_drawable_edit_text_bg"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:paddingLeft="5dp"
                            android:paddingTop="10dp"
                            android:paddingRight="5dp"
                            android:paddingBottom="10dp">

                            <TextView
                                android:id="@+id/tv_date_from"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:layout_marginTop="5dp"
                                android:drawableLeft="@drawable/calender"
                                android:drawablePadding="5dp"
                                android:gravity="center"
                                android:visibility="invisible"
                                android:text="START DATE"
                                android:textColor="@color/blue_app"
                                android:textSize="12dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/ll_date_to"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:layout_marginRight="15dp"
                            android:layout_weight="1"
                            android:background="@drawable/shimmer_drawable_edit_text_bg"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:paddingLeft="5dp"
                            android:paddingTop="10dp"
                            android:paddingRight="5dp"
                            android:paddingBottom="10dp">

                            <TextView
                                android:id="@+id/tv_date_to"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:layout_marginTop="5dp"
                                android:drawableLeft="@drawable/calender"
                                android:drawablePadding="5dp"
                                android:visibility="invisible"
                                android:gravity="center"
                                android:text="END DATE"
                                android:textColor="@color/blue_app"
                                android:textSize="12dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <androidx.constraintlayout.widget.ConstraintLayout
                                android:id="@+id/linearLayout"
                                android:layout_width="0sp"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:visibility="gone"
                                android:layout_marginTop="@dimen/heightsize_100dp"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toBottomOf="@+id/datelayout"
                                app:layout_constraintVertical_bias="0.4">

                                <ImageView
                                    android:id="@+id/no_data"
                                    android:layout_width="@dimen/heightsize_40dp"
                                    android:layout_height="@dimen/heightsize_40dp"
                                    android:contentDescription="@string/app_name"
                                    android:src="@drawable/nodata"
                                    app:layout_constraintBottom_toBottomOf="parent"
                                    app:layout_constraintEnd_toEndOf="parent"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toTopOf="parent"/>

                                <TextView
                                    android:id="@+id/tv_nodata"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="16sp"
                                    android:fontFamily="@font/dmsans_medium"
                                    android:text="@string/label_no_data"
                                    android:textColor="@color/black"
                                    android:textSize="13dp"
                                    app:layout_constraintTop_toBottomOf="@+id/no_data"
                                    app:layout_constraintEnd_toEndOf="parent"
                                    app:layout_constraintStart_toStartOf="parent"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/heightsize_6dp"
                                    android:fontFamily="@font/dmsans_regular"
                                    android:text="@string/label_no_data_detail"
                                    android:textColor="@color/black"
                                    android:textSize="12dp"
                                    app:layout_constraintTop_toBottomOf="@+id/tv_nodata"
                                    app:layout_constraintEnd_toEndOf="parent"
                                    app:layout_constraintStart_toStartOf="parent"/>
                            </androidx.constraintlayout.widget.ConstraintLayout>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:id="@+id/materialcard1"
                        app:cardElevation="@dimen/heightsize_6dp"
                        app:layout_constraintTop_toBottomOf="@+id/datelayout"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:layout_marginTop="@dimen/heightsize_16dp"
                        android:layout_marginHorizontal="@dimen/heightsize_16dp"
                        app:cardBackgroundColor="@color/color_C5C5C5"
                        app:cardCornerRadius="@dimen/_10sdp"
                        android:layout_height="@dimen/heightsize_150dp"/>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:id="@+id/materialcard2"
                        app:cardElevation="@dimen/heightsize_6dp"
                        app:layout_constraintTop_toBottomOf="@+id/materialcard1"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:layout_marginTop="@dimen/heightsize_16dp"
                        android:layout_marginHorizontal="@dimen/heightsize_16dp"
                        app:cardBackgroundColor="@color/color_C5C5C5"
                        app:cardCornerRadius="@dimen/_10sdp"
                        android:layout_height="@dimen/heightsize_150dp"/>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:id="@+id/materialcard3"
                        app:cardElevation="@dimen/heightsize_6dp"
                        app:layout_constraintTop_toBottomOf="@+id/materialcard2"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:layout_marginTop="@dimen/heightsize_16dp"
                        android:layout_marginHorizontal="@dimen/heightsize_16dp"
                        app:cardBackgroundColor="@color/color_C5C5C5"
                        app:cardCornerRadius="@dimen/_10sdp"
                        android:layout_height="@dimen/heightsize_150dp"/>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:id="@+id/materialcard4"
                        app:cardElevation="@dimen/heightsize_6dp"
                        app:layout_constraintTop_toBottomOf="@+id/materialcard3"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:layout_marginTop="@dimen/heightsize_16dp"
                        android:layout_marginHorizontal="@dimen/heightsize_16dp"
                        app:cardBackgroundColor="@color/color_C5C5C5"
                        app:cardCornerRadius="@dimen/_10sdp"
                        android:layout_height="@dimen/heightsize_150dp"/>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:id="@+id/materialcard5"
                        app:cardElevation="@dimen/heightsize_6dp"
                        app:layout_constraintTop_toBottomOf="@+id/materialcard4"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:layout_marginTop="@dimen/heightsize_16dp"
                        android:layout_marginHorizontal="@dimen/heightsize_16dp"
                        app:cardBackgroundColor="@color/color_C5C5C5"
                        app:cardCornerRadius="@dimen/_10sdp"
                        android:layout_height="@dimen/heightsize_150dp"/>
                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.core.widget.NestedScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>


