<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">


    <RelativeLayout
        android:id="@+id/rootview"
        android:layout_width="match_parent"
        android:orientation="vertical"
        android:background="@color/transparent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="@drawable/rectangle_solid_white_top_rounded_16"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <View
                    android:layout_width="@dimen/heightsize_60dp"
                    android:layout_gravity="center"
                    android:background="@color/white_60"
                    android:layout_marginTop="10dp"
                    android:layout_height="3dp">

                </View>

            </LinearLayout>

            <androidx.core.widget.NestedScrollView
                android:id="@+id/svLogin"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:scrollbars="none"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/includeLayout">


                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:paddingTop="@dimen/heightsize_12dp"
                    android:paddingBottom="@dimen/heightsize_12dp"
                    android:paddingHorizontal="@dimen/heightsize_16dp"
                    android:layout_height="match_parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:paddingTop="@dimen/heightsize_12dp"
                    android:id="@id/recieptlayout"
                    android:paddingBottom="@dimen/heightsize_12dp"
                    android:paddingHorizontal="@dimen/heightsize_16dp"
                    android:layout_height="match_parent">
                    <ImageView
                        android:layout_width="@dimen/heightsize_150dp"
                        android:src="@drawable/logo"
                        android:id="@+id/logo"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        android:layout_height="@dimen/heightsize_40dp">

                    </ImageView>

                    <pl.droidsonroids.gif.GifImageView
                        android:layout_width="@dimen/heightsize_80dp"
                        android:src="@drawable/succes"
                        android:id="@+id/statuslogo"
                        android:visibility="gone"
                        android:layout_marginVertical="@dimen/heightsize_5dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/logo"
                        android:layout_height="@dimen/heightsize_80dp">

                    </pl.droidsonroids.gif.GifImageView>

                    <TextView
                        android:id="@+id/tvtvtitle"
                        style="@style/TitleStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/heightsize_10dp"
                        android:layout_weight="1"
                        android:gravity="center"

                        app:layout_constraintTop_toBottomOf="@+id/statuslogo"
                        app:layout_constraintStart_toStartOf="parent"
                        android:text="@string/text_receipt"
                        android:textColor="@color/black"
                        android:textSize="16sp"
                        android:visibility="visible" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:id="@+id/line5"
                        android:layout_marginHorizontal="@dimen/heightsize_16dp"
                        app:layout_constraintTop_toBottomOf="@+id/tvtvtitle"
                        android:layout_marginTop="10sp"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_height="wrap_content">


                        <TextView
                            android:id="@+id/lbl_date"
                            style="@style/cardlabelStyle"
                            android:minWidth="130sp"
                            android:layout_width="wrap_content"
                            app:layout_constraintTop_toTopOf="parent"
                            android:text="@string/lbl_date"

                            app:layout_constraintStart_toStartOf="parent"
                            />

                        <TextView
                            android:id="@+id/date"
                            style="@style/cardtextStyle"
                            android:minWidth="100sp"
                            android:layout_width="0dp"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/lbl_date"
                            />

                        <View
                            android:layout_width="wrap_content"
                            android:layout_marginTop="7sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/date"
                            android:background="@color/color_C7BFBF"
                            android:layout_height="0.5dp">

                        </View>

                    </androidx.constraintlayout.widget.ConstraintLayout>



                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:id="@+id/line13"
                        android:layout_marginHorizontal="@dimen/heightsize_16dp"
                        app:layout_constraintTop_toBottomOf="@+id/line5"
                        android:layout_marginTop="10sp"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_height="wrap_content">


                        <TextView
                            android:id="@+id/lbl_op_name"
                            style="@style/cardlabelStyle"
                            android:minWidth="130sp"
                            android:layout_width="wrap_content"
                            app:layout_constraintTop_toTopOf="parent"
                            android:text="@string/lbl_customer_name"

                            app:layout_constraintStart_toStartOf="parent"
                            />

                        <TextView
                            android:id="@+id/tx_name"
                            style="@style/cardtextStyle"
                            android:minWidth="100sp"
                            android:layout_width="0dp"
                            app:layout_constraintTop_toTopOf="parent"

                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/lbl_op_name"
                            />

                        <View
                            android:layout_width="wrap_content"
                            android:layout_marginTop="7sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/tx_name"
                            android:background="@color/color_C7BFBF"
                            android:layout_height="0.5dp">

                        </View>

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:id="@+id/line3"
                        android:layout_marginHorizontal="@dimen/heightsize_16dp"
                        app:layout_constraintTop_toBottomOf="@+id/line13"
                        android:layout_marginTop="10sp"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_height="wrap_content">


                        <TextView
                            android:id="@+id/lbl_txid"
                            style="@style/cardlabelStyle"
                            android:minWidth="130sp"
                            android:layout_width="wrap_content"
                            app:layout_constraintTop_toTopOf="parent"
                            android:text="@string/lbl_tx_id"

                            app:layout_constraintStart_toStartOf="parent"
                            />

                        <TextView
                            android:id="@+id/tx_id"
                            style="@style/cardtextStyle"
                            android:minWidth="100sp"
                            android:layout_width="0dp"
                            app:layout_constraintTop_toTopOf="parent"

                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/lbl_txid"
                            />

                        <View
                            android:layout_width="wrap_content"
                            android:layout_marginTop="7sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/tx_id"
                            android:background="@color/color_C7BFBF"
                            android:layout_height="0.5dp">

                        </View>

                    </androidx.constraintlayout.widget.ConstraintLayout>
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:id="@+id/line6"
                        android:layout_marginHorizontal="@dimen/heightsize_16dp"
                        app:layout_constraintTop_toBottomOf="@+id/line3"
                        android:layout_marginTop="10sp"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_height="wrap_content">


                        <TextView
                            android:id="@+id/lbl_status"
                            style="@style/cardlabelStyle"
                            android:minWidth="130sp"
                            android:layout_width="wrap_content"
                            app:layout_constraintTop_toTopOf="parent"
                            android:text="@string/lbl_status"

                            app:layout_constraintStart_toStartOf="parent"
                            />

                        <TextView
                            android:id="@+id/status"
                            style="@style/cardtextStyle"
                            android:minWidth="100sp"
                            android:layout_width="0dp"
                            android:textColor="@color/color_259A2A"
                            app:layout_constraintTop_toTopOf="parent"
                            android:text="Success"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/lbl_status"
                            />

                        <View
                            android:layout_width="wrap_content"
                            android:layout_marginTop="7sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/status"
                            android:background="@color/color_C7BFBF"
                            android:layout_height="0.5dp">

                        </View>




                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:id="@+id/line4"
                        android:layout_marginHorizontal="@dimen/heightsize_16dp"
                        app:layout_constraintTop_toBottomOf="@+id/line6"
                        android:layout_marginTop="10sp"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_height="wrap_content">


                        <TextView
                            android:id="@+id/lbl_amount"
                            style="@style/cardlabelStyle"
                            android:minWidth="130sp"
                            android:layout_width="wrap_content"
                            app:layout_constraintTop_toTopOf="parent"
                            android:text="@string/lbl_account_no"

                            app:layout_constraintStart_toStartOf="parent"
                            />

                        <TextView
                            android:id="@+id/accountnumber"
                            style="@style/cardtextStyle"
                            android:minWidth="100sp"
                            android:layout_width="0dp"
                            app:layout_constraintTop_toTopOf="parent"

                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/lbl_amount"
                            />

                        <View
                            android:layout_width="wrap_content"
                            android:layout_marginTop="7sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/accountnumber"
                            android:background="@color/color_C7BFBF"
                            android:layout_height="0.5dp">

                        </View>

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:id="@+id/line14"
                        android:layout_marginHorizontal="@dimen/heightsize_16dp"
                        app:layout_constraintTop_toBottomOf="@+id/line4"
                        android:layout_marginTop="10sp"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_height="wrap_content">


                        <TextView
                            android:id="@+id/lbl_txn"
                            style="@style/cardlabelStyle"
                            android:minWidth="130sp"
                            android:layout_width="wrap_content"
                            app:layout_constraintTop_toTopOf="parent"
                            android:text="@string/lbl_ifsc_code_dash"

                            app:layout_constraintStart_toStartOf="parent"
                            />

                        <TextView
                            android:id="@+id/ifsc"
                            style="@style/cardtextStyle"
                            android:minWidth="100sp"
                            android:layout_width="0dp"
                            app:layout_constraintTop_toTopOf="parent"

                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/lbl_txn"
                            />

                        <View
                            android:layout_width="wrap_content"
                            android:layout_marginTop="7sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/ifsc"
                            android:background="@color/color_C7BFBF"
                            android:layout_height="0.5dp">

                        </View>

                    </androidx.constraintlayout.widget.ConstraintLayout>
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:id="@+id/line15"
                        android:layout_marginHorizontal="@dimen/heightsize_16dp"
                        app:layout_constraintTop_toBottomOf="@+id/line14"
                        android:layout_marginTop="10sp"
                        android:visibility="gone"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_height="wrap_content">


                        <TextView
                            android:id="@+id/lbl_msg"
                            style="@style/cardlabelStyle"
                            android:minWidth="130sp"
                            android:layout_width="wrap_content"
                            app:layout_constraintTop_toTopOf="parent"
                            android:text="@string/label_rrn"

                            app:layout_constraintStart_toStartOf="parent"
                            />

                        <TextView
                            android:id="@+id/rrn"
                            style="@style/cardtextStyle"
                            android:minWidth="100sp"
                            android:layout_width="0dp"
                            app:layout_constraintTop_toTopOf="parent"

                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/lbl_msg"
                            />

                        <View
                            android:layout_width="wrap_content"
                            android:layout_marginTop="7sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/rrn"
                            android:background="@color/color_C7BFBF"
                            android:layout_height="0.5dp">

                        </View>

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:id="@+id/line16"
                        android:layout_marginHorizontal="@dimen/heightsize_16dp"
                        app:layout_constraintTop_toBottomOf="@+id/line15"
                        android:layout_marginTop="10sp"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_height="wrap_content">


                        <TextView
                            android:id="@+id/lbl_qt"
                            style="@style/cardlabelStyle"
                            android:minWidth="130sp"
                            android:layout_width="wrap_content"
                            app:layout_constraintTop_toTopOf="parent"
                            android:text="@string/lbl_quicktransfer"

                            app:layout_constraintStart_toStartOf="parent"
                            />

                        <TextView
                            android:id="@+id/qtamount"
                            style="@style/cardtextStyle"
                            android:minWidth="100sp"
                            android:layout_width="0dp"
                            app:layout_constraintTop_toTopOf="parent"

                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/lbl_qt"
                            />

                        <View
                            android:layout_width="wrap_content"
                            android:layout_marginTop="7sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/qtamount"
                            android:background="@color/color_C7BFBF"
                            android:layout_height="0.5dp">

                        </View>

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:id="@+id/line20"
                        android:layout_marginHorizontal="@dimen/heightsize_16dp"
                        app:layout_constraintTop_toBottomOf="@+id/line16"
                        android:layout_marginTop="10sp"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_height="wrap_content">


                        <TextView
                            android:id="@+id/lbl_charge"
                            style="@style/cardlabelStyle"
                            android:minWidth="130sp"
                            android:layout_width="wrap_content"
                            app:layout_constraintTop_toTopOf="parent"
                            android:text="@string/lbl_qt_charge"

                            app:layout_constraintStart_toStartOf="parent"
                            />

                        <TextView
                            android:id="@+id/qtcharge"
                            style="@style/cardtextStyle"
                            android:minWidth="100sp"
                            android:layout_width="0dp"
                            app:layout_constraintTop_toTopOf="parent"

                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/lbl_charge"
                            />

                        <View
                            android:layout_width="wrap_content"
                            android:layout_marginTop="7sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/qtcharge"
                            android:background="@color/color_C7BFBF"
                            android:layout_height="0.5dp">

                        </View>

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:id="@+id/line19"
                        android:layout_marginHorizontal="@dimen/heightsize_16dp"
                        app:layout_constraintTop_toBottomOf="@+id/line20"
                        android:layout_marginTop="10sp"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_height="wrap_content">


                        <TextView
                            android:id="@+id/lbl_mobile"
                            style="@style/cardlabelStyle"
                            android:minWidth="130sp"
                            android:layout_width="wrap_content"
                            app:layout_constraintTop_toTopOf="parent"
                            android:text="@string/lbl_Total"

                            app:layout_constraintStart_toStartOf="parent"
                            />

                        <TextView
                            android:id="@+id/total"
                            style="@style/cardtextStyle"
                            android:minWidth="100sp"
                            android:layout_width="0dp"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/lbl_mobile"
                            />

                        <View
                            android:layout_width="wrap_content"
                            android:layout_marginTop="7sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/total"
                            android:background="@color/color_C7BFBF"
                            android:layout_height="0.5dp">

                        </View>

                    </androidx.constraintlayout.widget.ConstraintLayout>


                 </androidx.constraintlayout.widget.ConstraintLayout>


                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:layout_constraintTop_toBottomOf="@id/recieptlayout"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnprint"
                            style="@style/ThemeAppButton"
                            android:layout_width="0dp"
                            android:layout_height="@dimen/heightsize_50dp"
                            android:text="Print"
                            android:textAllCaps="false"
                            android:layout_marginStart="16dp"
                            android:layout_marginEnd="8dp"
                            android:layout_marginTop="16dp"
                            android:layout_marginBottom="26dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/btnConfirm"
                            app:layout_constraintTop_toTopOf="parent"
                           />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnConfirm"
                            style="@style/ThemeAppButton"
                            android:layout_width="0dp"
                            android:layout_height="@dimen/heightsize_50dp"
                            android:text="Confirm"
                            android:textAllCaps="false"
                            android:layout_marginStart="8dp"
                            android:layout_marginEnd="16dp"
                            app:layout_constraintStart_toEndOf="@id/btnprint"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@id/btnprint" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>




            </androidx.core.widget.NestedScrollView>

        </LinearLayout>



    </RelativeLayout>

</layout>