<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">


    <RelativeLayout
        android:id="@+id/rootview"
        android:layout_width="match_parent"
        android:orientation="vertical"
        android:background="@color/transparent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="@drawable/rectangle_solid_white_top_rounded_16"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <View
                    android:layout_width="@dimen/heightsize_60dp"
                    android:layout_gravity="center"
                    android:background="@color/white_60"
                    android:layout_marginTop="10dp"
                    android:layout_height="3dp">

                </View>




            </LinearLayout>



            <androidx.core.widget.NestedScrollView
                android:id="@+id/svLogin"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:scrollbars="none"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/includeLayout">



                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:paddingTop="@dimen/heightsize_12dp"
                    android:id="@+id/mainlayout"
                    android:paddingBottom="@dimen/heightsize_12dp"
                    android:paddingHorizontal="@dimen/heightsize_16dp"
                    android:layout_height="match_parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:paddingTop="@dimen/heightsize_12dp"
                    android:id="@id/recieptlayout"
                    android:paddingBottom="@dimen/heightsize_12dp"
                    android:paddingHorizontal="@dimen/heightsize_16dp"
                    android:layout_height="match_parent">


                    <ImageView
                        android:layout_width="@dimen/heightsize_150dp"
                        android:src="@drawable/logo"
                        android:id="@+id/logo"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        android:layout_height="@dimen/heightsize_40dp">

                    </ImageView>

                    <pl.droidsonroids.gif.GifImageView
                        android:layout_width="@dimen/heightsize_80dp"
                        android:src="@drawable/succes"
                        android:id="@+id/statuslogo"
                        android:layout_marginVertical="@dimen/heightsize_5dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/logo"
                        android:layout_height="@dimen/heightsize_80dp">

                    </pl.droidsonroids.gif.GifImageView>

                    <TextView
                        android:id="@+id/tvtvtitle"
                        style="@style/TitleStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/heightsize_10dp"
                        android:layout_weight="1"
                        android:gravity="center"

                        app:layout_constraintTop_toBottomOf="@+id/statuslogo"
                        app:layout_constraintStart_toStartOf="parent"
                        android:text="@string/text_receipt"
                        android:textColor="@color/black"
                        android:textSize="16sp"
                        android:visibility="visible" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:id="@+id/line5"
                        android:layout_marginHorizontal="@dimen/heightsize_16dp"
                        app:layout_constraintTop_toBottomOf="@+id/tvtvtitle"
                        android:layout_marginTop="10sp"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_height="wrap_content">


                        <TextView
                            android:id="@+id/lbl_date"
                            style="@style/cardlabelStyle"
                            android:minWidth="130sp"
                            android:layout_width="wrap_content"
                            app:layout_constraintTop_toTopOf="parent"
                            android:text="@string/lbl_date"

                            app:layout_constraintStart_toStartOf="parent"
                            />

                        <TextView
                            android:id="@+id/date"
                            style="@style/cardtextStyle"
                            android:minWidth="100sp"
                            android:layout_width="0dp"
                            app:layout_constraintTop_toTopOf="parent"
                            android:text=""
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/lbl_date"
                            />

                        <View
                            android:layout_width="wrap_content"
                            android:layout_marginTop="7sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/date"
                            android:background="@color/color_C7BFBF"
                            android:layout_height="0.5dp">

                        </View>

                    </androidx.constraintlayout.widget.ConstraintLayout>



                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:id="@+id/line13"
                        android:layout_marginHorizontal="@dimen/heightsize_16dp"
                        app:layout_constraintTop_toBottomOf="@+id/line5"
                        android:layout_marginTop="10sp"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_height="wrap_content">


                        <TextView
                            android:id="@+id/lbl_op_name"
                            style="@style/cardlabelStyle"
                            android:minWidth="130sp"
                            android:layout_width="wrap_content"
                            app:layout_constraintTop_toTopOf="parent"
                            android:text="@string/lbl_type"

                            app:layout_constraintStart_toStartOf="parent"
                            />

                        <TextView
                            android:id="@+id/tx_type"
                            style="@style/cardtextStyle"
                            android:minWidth="100sp"
                            android:layout_width="0dp"
                            app:layout_constraintTop_toTopOf="parent"
                            android:text=""
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/lbl_op_name"
                            />

                        <View
                            android:layout_width="wrap_content"
                            android:layout_marginTop="7sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/tx_type"
                            android:background="@color/color_C7BFBF"
                            android:layout_height="0.5dp">

                        </View>

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:id="@+id/line3"
                        android:layout_marginHorizontal="@dimen/heightsize_16dp"
                        app:layout_constraintTop_toBottomOf="@+id/line13"
                        android:layout_marginTop="10sp"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_height="wrap_content">


                        <TextView
                            android:id="@+id/lbl_txid"
                            style="@style/cardlabelStyle"
                            android:minWidth="130sp"
                            android:layout_width="wrap_content"
                            app:layout_constraintTop_toTopOf="parent"
                            android:text="@string/lbl_tx_id"

                            app:layout_constraintStart_toStartOf="parent"
                            />

                        <TextView
                            android:id="@+id/tx_id"
                            style="@style/cardtextStyle"
                            android:minWidth="100sp"
                            android:layout_width="0dp"
                            app:layout_constraintTop_toTopOf="parent"
                            android:text=""
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/lbl_txid"
                            />

                        <View
                            android:layout_width="wrap_content"
                            android:layout_marginTop="7sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/tx_id"
                            android:background="@color/color_C7BFBF"
                            android:layout_height="0.5dp">

                        </View>

                    </androidx.constraintlayout.widget.ConstraintLayout>
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:id="@+id/line6"
                        android:layout_marginHorizontal="@dimen/heightsize_16dp"
                        app:layout_constraintTop_toBottomOf="@+id/line3"
                        android:layout_marginTop="10sp"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_height="wrap_content">


                        <TextView
                            android:id="@+id/lbl_status"
                            style="@style/cardlabelStyle"
                            android:minWidth="130sp"
                            android:layout_width="wrap_content"
                            app:layout_constraintTop_toTopOf="parent"
                            android:text="@string/lbl_status"

                            app:layout_constraintStart_toStartOf="parent"
                            />

                        <TextView
                            android:id="@+id/status"
                            style="@style/cardtextStyle"
                            android:minWidth="100sp"
                            android:layout_width="0dp"
                            android:textColor="@color/color_259A2A"
                            app:layout_constraintTop_toTopOf="parent"
                            android:text="Success"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/lbl_status"
                            />

                        <View
                            android:layout_width="wrap_content"
                            android:layout_marginTop="7sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/status"
                            android:background="@color/color_C7BFBF"
                            android:layout_height="0.5dp">

                        </View>




                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:id="@+id/line4"
                        android:layout_marginHorizontal="@dimen/heightsize_16dp"
                        app:layout_constraintTop_toBottomOf="@+id/line6"
                        android:layout_marginTop="10sp"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_height="wrap_content">


                        <TextView
                            android:id="@+id/lbl_amount"
                            style="@style/cardlabelStyle"
                            android:minWidth="130sp"
                            android:layout_width="wrap_content"
                            app:layout_constraintTop_toTopOf="parent"
                            android:text="@string/lbl_remaining_amount"

                            app:layout_constraintStart_toStartOf="parent"
                            />

                        <TextView
                            android:id="@+id/amount"
                            style="@style/cardtextStyle"
                            android:minWidth="100sp"
                            android:layout_width="0dp"
                            app:layout_constraintTop_toTopOf="parent"
                            android:text=""
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/lbl_amount"
                            />

                        <View
                            android:layout_width="wrap_content"
                            android:layout_marginTop="7sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/amount"
                            android:background="@color/color_C7BFBF"
                            android:layout_height="0.5dp">

                        </View>

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:id="@+id/line14"
                        android:layout_marginHorizontal="@dimen/heightsize_16dp"
                        app:layout_constraintTop_toBottomOf="@+id/line4"
                        android:layout_marginTop="10sp"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_height="wrap_content">


                        <TextView
                            android:id="@+id/lbl_txn"
                            style="@style/cardlabelStyle"
                            android:minWidth="130sp"
                            android:layout_width="wrap_content"
                            app:layout_constraintTop_toTopOf="parent"
                            android:text="@string/lbl_txn_amount"

                            app:layout_constraintStart_toStartOf="parent"
                            />

                        <TextView
                            android:id="@+id/txnamount"
                            style="@style/cardtextStyle"
                            android:minWidth="100sp"
                            android:layout_width="0dp"
                            app:layout_constraintTop_toTopOf="parent"
                            android:text=""
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/lbl_txn"
                            />

                        <View
                            android:layout_width="wrap_content"
                            android:layout_marginTop="7sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/txnamount"
                            android:background="@color/color_C7BFBF"
                            android:layout_height="0.5dp">

                        </View>

                    </androidx.constraintlayout.widget.ConstraintLayout>
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:id="@+id/line15"
                        android:layout_marginHorizontal="@dimen/heightsize_16dp"
                        app:layout_constraintTop_toBottomOf="@+id/line14"
                        android:layout_marginTop="10sp"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_height="wrap_content">


                        <TextView
                            android:id="@+id/lbl_msg"
                            style="@style/cardlabelStyle"
                            android:minWidth="130sp"
                            android:layout_width="wrap_content"
                            app:layout_constraintTop_toTopOf="parent"
                            android:text="@string/lbl_message"

                            app:layout_constraintStart_toStartOf="parent"
                            />

                        <TextView
                            android:id="@+id/msg"
                            style="@style/cardtextStyle"
                            android:minWidth="100sp"
                            android:layout_width="0dp"
                            app:layout_constraintTop_toTopOf="parent"
                            android:text=""
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/lbl_msg"
                            />

                        <View
                            android:layout_width="wrap_content"
                            android:layout_marginTop="7sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/msg"
                            android:background="@color/color_C7BFBF"
                            android:layout_height="0.5dp">

                        </View>

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:id="@+id/line16"
                        android:layout_marginHorizontal="@dimen/heightsize_16dp"
                        app:layout_constraintTop_toBottomOf="@+id/line15"
                        android:layout_marginTop="10sp"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_height="wrap_content">


                        <TextView
                            android:id="@+id/lbl_aadhaar"
                            style="@style/cardlabelStyle"
                            android:minWidth="130sp"
                            android:layout_width="wrap_content"
                            app:layout_constraintTop_toTopOf="parent"
                            android:text="@string/lbl_adhar"

                            app:layout_constraintStart_toStartOf="parent"
                            />

                        <TextView
                            android:id="@+id/aadhaar"
                            style="@style/cardtextStyle"
                            android:minWidth="100sp"
                            android:layout_width="0dp"
                            app:layout_constraintTop_toTopOf="parent"
                            android:text=""
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/lbl_aadhaar"
                            />

                        <View
                            android:layout_width="wrap_content"
                            android:layout_marginTop="7sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/aadhaar"
                            android:background="@color/color_C7BFBF"
                            android:layout_height="0.5dp">

                        </View>

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:id="@+id/line20"
                        android:layout_marginHorizontal="@dimen/heightsize_16dp"
                        app:layout_constraintTop_toBottomOf="@+id/line16"
                        android:layout_marginTop="10sp"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_height="wrap_content">


                        <TextView
                            android:id="@+id/lbl_bank"
                            style="@style/cardlabelStyle"
                            android:minWidth="130sp"
                            android:layout_width="wrap_content"
                            app:layout_constraintTop_toTopOf="parent"
                            android:text="@string/lbl_bank"

                            app:layout_constraintStart_toStartOf="parent"
                            />

                        <TextView
                            android:id="@+id/bank"
                            style="@style/cardtextStyle"
                            android:minWidth="100sp"
                            android:layout_width="0dp"
                            app:layout_constraintTop_toTopOf="parent"
                            android:text=""
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/lbl_bank"
                            />

                        <View
                            android:layout_width="wrap_content"
                            android:layout_marginTop="7sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/bank"
                            android:background="@color/color_C7BFBF"
                            android:layout_height="0.5dp">

                        </View>

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:id="@+id/line19"
                        android:layout_marginHorizontal="@dimen/heightsize_16dp"
                        app:layout_constraintTop_toBottomOf="@+id/line20"
                        android:layout_marginTop="10sp"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_height="wrap_content">


                        <TextView
                            android:id="@+id/lbl_mobile"
                            style="@style/cardlabelStyle"
                            android:minWidth="130sp"
                            android:layout_width="wrap_content"
                            app:layout_constraintTop_toTopOf="parent"
                            android:text="@string/label_mobile_number"

                            app:layout_constraintStart_toStartOf="parent"
                            />

                        <TextView
                            android:id="@+id/mobile"
                            style="@style/cardtextStyle"
                            android:minWidth="100sp"
                            android:layout_width="0dp"
                            app:layout_constraintTop_toTopOf="parent"
                            android:text=""
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/lbl_mobile"
                            />

                        <View
                            android:layout_width="wrap_content"
                            android:layout_marginTop="7sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/mobile"
                            android:background="@color/color_C7BFBF"
                            android:layout_height="0.5dp">

                        </View>

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:id="@+id/line18"
                        android:layout_marginHorizontal="@dimen/heightsize_16dp"
                        app:layout_constraintTop_toBottomOf="@+id/line19"
                        android:layout_marginTop="10sp"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_height="wrap_content">


                        <TextView
                            android:id="@+id/lbl_rrn"
                            style="@style/cardlabelStyle"
                            android:minWidth="130sp"
                            android:layout_width="wrap_content"
                            app:layout_constraintTop_toTopOf="parent"
                            android:text="@string/label_rrn"

                            app:layout_constraintStart_toStartOf="parent"
                            />

                        <TextView
                            android:id="@+id/rrn"
                            style="@style/cardtextStyle"
                            android:minWidth="100sp"
                            android:layout_width="0dp"
                            app:layout_constraintTop_toTopOf="parent"
                            android:text=""
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/lbl_rrn"
                            />

                        <View
                            android:layout_width="wrap_content"
                            android:layout_marginTop="7sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/rrn"
                            android:background="@color/color_C7BFBF"
                            android:layout_height="0.5dp">

                        </View>

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:id="@+id/transationlayout"
                        android:visibility="gone"
                        android:layout_marginBottom="@dimen/heightsize_15dp"
                        app:layout_constraintTop_toBottomOf="@+id/line18"
                        android:layout_height="wrap_content">

                        <TextView
                            android:id="@+id/tvtransatiion"
                            style="@style/TitleStyle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/heightsize_10dp"
                            android:layout_weight="1"
                            android:gravity="center"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            android:text=""
                            android:textColor="@color/black"
                            android:textSize="16sp"
                            android:visibility="visible" />

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:id="@+id/materialcard"
                            app:cardElevation="@dimen/heightsize_6dp"
                            android:layout_marginHorizontal="@dimen/heightsize_5dp"
                            app:layout_constraintTop_toBottomOf="@+id/tvtransatiion"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            android:layout_marginTop="@dimen/heightsize_10dp"
                            app:cardBackgroundColor="@color/white"
                            app:cardCornerRadius="@dimen/_10sdp"
                            android:layout_height="wrap_content">


                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:paddingTop="@dimen/heightsize_12dp"
                            android:paddingBottom="@dimen/heightsize_12dp"
                            android:layout_height="match_parent">
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/fetchbillrecycler"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:layout_marginTop="@dimen/heightsize_16dp"
                            android:overScrollMode="never"
                            android:clipToPadding="false"
                            android:paddingBottom="@dimen/heightsize_16dp"
                            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            tools:listitem="@layout/aeps_ministatement_layout" />

                        </androidx.constraintlayout.widget.ConstraintLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <androidx.viewpager.widget.ViewPager
                            android:layout_width="wrap_content"
                            android:id="@+id/view1"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/materialcard"
                            android:layout_height="5dp">

                        </androidx.viewpager.widget.ViewPager>


                    </androidx.constraintlayout.widget.ConstraintLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"

                        app:layout_constraintTop_toBottomOf="@+id/recieptlayout">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:padding="0dp"

                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnprint"
                                style="@style/ThemeAppButton"
                                android:layout_width="wrap_content"
                                android:layout_height="@dimen/heightsize_50dp"
                                android:text="@string/btn_print"
                                android:textAllCaps="false"
                                android:layout_marginStart="3dp"/>


                            <!-- Center Button -->
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnanother"
                                style="@style/ThemeAppButton"
                                android:layout_width="wrap_content"
                                android:layout_height="@dimen/heightsize_70dp"
                                android:text="Another\nTransaction"
                                android:textAllCaps="false"
                                android:gravity="center"
                                android:layout_marginStart="3dp"
                                android:layout_marginEnd="3dp"
                                android:paddingHorizontal="3dp"/>

                            <!-- Last Button -->
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnConfirm"
                                style="@style/ThemeAppButton"
                                android:layout_width="wrap_content"
                                android:layout_height="@dimen/heightsize_50dp"
                                android:text="@string/btn_close"
                                android:textAllCaps="false"
                                android:layout_marginStart="3dp"/>

                        </LinearLayout>

                    </androidx.constraintlayout.widget.ConstraintLayout>


                </androidx.constraintlayout.widget.ConstraintLayout>




            </androidx.core.widget.NestedScrollView>

        </LinearLayout>



    </RelativeLayout>

</layout>